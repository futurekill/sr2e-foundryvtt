node_modules/
.DS_Store
*.log
# LevelDB compendium packs are a BUILD ARTIFACT regenerated from packs-src/ by
# `npm run build-packs`. Not tracked: Foundry compacts these every session
# (churning the working tree with no content change). The release workflow
# rebuilds them from packs-src before packaging, so releases still ship packs.
/packs/
.env

# Re-include the system's SVG icons: the user's global ~/.gitignore_global
# "Icon?" rule (macOS Finder Icon files) matches the "icons" dir name
# case-insensitively and was silently dropping these from releases.
!assets/icons/
!assets/icons/*
_work/
graphify-out/
