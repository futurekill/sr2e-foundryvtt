node_modules/
.DS_Store
*.log
# LevelDB compendium packs store recent writes in *.log files — they MUST be
# tracked or cloned/released packs lose data. Re-include them explicitly.
!packs/**/*.log
.env

# Re-include the system's SVG icons: the user's global ~/.gitignore_global
# "Icon?" rule (macOS Finder Icon files) matches the "icons" dir name
# case-insensitively and was silently dropping these from releases.
!assets/icons/
!assets/icons/*
