{
  "id": "sr2e",
  "title": "Shadowrun 2nd Edition",
  "description": "A comprehensive game system for Shadowrun Second Edition (FASA 7901) built for Foundry Virtual Tabletop.",
  "version": "0.3.76",
  "url": "https://github.com/futurekill/sr2e-foundryvtt",
  "manifest": "https://github.com/futurekill/sr2e-foundryvtt/releases/latest/download/system.json",
  "download": "https://github.com/futurekill/sr2e-foundryvtt/releases/download/v0.3.8/sr2e.zip",
  "bugs": "https://github.com/futurekill/sr2e-foundryvtt/issues",
  "changelog": "https://github.com/futurekill/sr2e-foundryvtt/releases",
  "authors": [
    {
      "name": "James Candalino",
      "email": "jcandali@gmail.com",
      "url": "https://github.com/futurekill"
    }
  ],
  "compatibility": {
    "minimum": 13,
    "verified": 13
  },
  "esmodules": ["module/sr2e.mjs"],
  "styles": ["css/sr2e-main.css"],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "documentTypes": {
    "Actor": {
      "character": {
        "htmlFields": ["biography", "notes"]
      },
      "npc": {
        "htmlFields": ["biography"]
      },
      "vehicle": {
        "htmlFields": ["notes"]
      },
      "spirit": {
        "htmlFields": ["notes"]
      },
      "ic": {
        "htmlFields": ["notes"]
      }
    },
    "Item": {
      "skill": {},
      "weapon": {},
      "armor": {},
      "spell": {},
      "cyberware": {},
      "gear": {},
      "program": {},
      "adept_power": {
        "htmlFields": ["description"]
      },
      "contact": {
        "htmlFields": ["description"]
      },
      "lifestyle": {
        "htmlFields": ["description"]
      },
      "ammo": {},
      "focus": {},
      "vehicle_mod": {},
      "race": {
        "htmlFields": ["description"]
      },
      "tradition": {
        "htmlFields": ["description"]
      }
    }
  },
  "grid": {
    "type": 1,
    "distance": 1,
    "units": "m"
  },
  "primaryTokenAttribute": "conditionMonitor.physical",
  "secondaryTokenAttribute": "conditionMonitor.stun",
  "initiative": "1d6",
  "packs": [
    { "name": "skills",       "label": "SR2E Skills",         "path": "packs/skills",       "type": "Item",      "system": "sr2e", "folder": "Characters" },
    { "name": "contacts",     "label": "SR2E Contacts",       "path": "packs/contacts",     "type": "Item",      "system": "sr2e", "folder": "Characters" },
    { "name": "lifestyles",   "label": "SR2E Lifestyles",     "path": "packs/lifestyles",   "type": "Item",      "system": "sr2e", "folder": "Characters" },
    { "name": "weapons",      "label": "SR2E Weapons",        "path": "packs/weapons",      "type": "Item",      "system": "sr2e", "folder": "Combat" },
    { "name": "armor",        "label": "SR2E Armor",          "path": "packs/armor",        "type": "Item",      "system": "sr2e", "folder": "Combat" },
    { "name": "ammo",         "label": "SR2E Ammunition",     "path": "packs/ammo",         "type": "Item",      "system": "sr2e", "folder": "Combat" },
    { "name": "cyberware",    "label": "SR2E Cyberware",      "path": "packs/cyberware",    "type": "Item",      "system": "sr2e", "folder": "Augmentations" },
    { "name": "spells",       "label": "SR2E Spells",         "path": "packs/spells",       "type": "Item",      "system": "sr2e", "folder": "Magic" },
    { "name": "foci",         "label": "SR2E Magical Foci",   "path": "packs/foci",         "type": "Item",      "system": "sr2e", "folder": "Magic" },
    { "name": "adept-powers", "label": "SR2E Adept Powers",   "path": "packs/adept-powers", "type": "Item",      "system": "sr2e", "folder": "Magic" },
    { "name": "programs",     "label": "SR2E Matrix Programs","path": "packs/programs",     "type": "Item",      "system": "sr2e", "folder": "Matrix" },
    { "name": "gear",         "label": "SR2E Equipment",      "path": "packs/gear",         "type": "Item",      "system": "sr2e", "folder": "Equipment" },
    { "name": "roll-tables",  "label": "SR2E Roll Tables",    "path": "packs/roll-tables",  "type": "RollTable", "system": "sr2e", "folder": "Reference" },
    { "name": "races",        "label": "SR2E Metatypes",        "path": "packs/races",        "type": "Item",      "system": "sr2e", "folder": "Characters" },
    { "name": "traditions",   "label": "SR2E Traditions",       "path": "packs/traditions",   "type": "Item",      "system": "sr2e", "folder": "Magic" }
  ],
  "packFolders": [
    {
      "name": "Core Rules",
      "sorting": "m",
      "folders": [
        {
          "name": "Characters",
          "sorting": "a",
          "packs": ["races", "skills", "contacts", "lifestyles"]
        },
        {
          "name": "Combat",
          "sorting": "a",
          "packs": ["weapons", "armor", "ammo"]
        },
        {
          "name": "Magic",
          "sorting": "a",
          "packs": ["traditions", "spells", "foci", "adept-powers"]
        },
        {
          "name": "Augmentations",
          "sorting": "a",
          "packs": ["cyberware"]
        },
        {
          "name": "Matrix",
          "sorting": "a",
          "packs": ["programs"]
        },
        {
          "name": "Equipment",
          "sorting": "a",
          "packs": ["gear"]
        },
        {
          "name": "Reference",
          "sorting": "a",
          "packs": ["roll-tables"]
        }
      ]
    }
  ],
  "socket": true,
  "background": "systems/sr2e/assets/sr2e-logo.webp",
  "media": [
    {
      "type": "icon",
      "url": "systems/sr2e/assets/sr2e-logo.webp"
    }
  ],
  "flags": {}
}
