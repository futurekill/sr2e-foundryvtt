  </div>
  <div class="form-group">
    <label>Loaded:</label>
    <input type="checkbox" name="system.loaded" {{checked system.loaded}} />
  </div>
  {{/ifEquals}}

  {{!-- GEAR --}}
  {{#ifEquals type "gear"}}
