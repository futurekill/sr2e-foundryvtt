    <input type="number" name="system.deck.activeMemory" value="{{system.deck.activeMemory}}" min="0" /></div>
  <div class="form-group"><label>Storage Memory (Mp):</label>
    <input type="number" name="system.deck.storageMemory" value="{{system.deck.storageMemory}}" min="0" /></div>
