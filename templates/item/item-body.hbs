           title="Mark this as a weapon mod (Laser Sight, Smartgun System, Gas-vent, Gyro Mount, etc.) that attaches to one weapon." />
  </div>
  {{#if system.weaponAccessory}}
  <div class="form-group">
    <label>Attack TN Mod:</label>
    <input type="number" name="system.combatTnMod" value="{{system.combatTnMod}}"
           title="Modifier to the attached weapon's attack TN (e.g. Laser Sight −1)." />
  </div>
  <div class="form-group">
    <label>Recoil Comp:</label>
    <input type="number" name="system.accessoryRecoilComp" value="{{system.accessoryRecoilComp}}" min="0"
           title="Recoil compensation granted to the attached weapon (Gas-vent, Shock Pads, Bipod, Tripod). SR2E p.240–241." />
  </div>
  <div class="form-group">
    <label>Laser Sight:</label>
    <input type="checkbox" name="system.laserSight" {{checked system.laserSight}}
