<section class="item-body">

  {{!-- SKILL --}}
  {{#ifEquals type "skill"}}
  <div class="form-group">
    <label>Category:</label>
    <select name="system.category">
      {{#each config.skillCategories as |label key|}}
      <option value="{{key}}" {{selected ../system.category key}}>{{localize label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Linked Attribute:</label>
    <select name="system.linkedAttribute">
      {{#each config.attributes as |label key|}}
      <option value="{{key}}" {{selected ../system.linkedAttribute key}}>{{localize label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Rating:</label>
    <input type="number" name="system.rating" value="{{system.rating}}" min="0" max="12" />
  </div>
  <div class="form-group">
    <label>Concentration:</label>
    <input type="text" name="system.concentration.name" value="{{system.concentration.name}}" placeholder="e.g., Pistols" />
    {{#if system.concentration.name}}
    <span>Rating: {{system.concentration.rating}}</span>
    {{/if}}
  </div>
  <div class="form-group">
    <label>Specialization:</label>
    <input type="text" name="system.specialization.name" value="{{system.specialization.name}}" placeholder="e.g., Ares Predator" />
    {{#if system.specialization.name}}
    <span>Rating: {{system.specialization.rating}}</span>
    {{/if}}
  </div>
  <div class="form-group">
    <label>Magical Skill:</label>
    <input type="checkbox" name="system.isMagical" {{checked system.isMagical}} />
  </div>
  {{/ifEquals}}

  {{!-- WEAPON --}}
  {{#ifEquals type "weapon"}}
  <div class="form-group">
    <label>Weapon Type:</label>
    <select name="system.weaponType">
      {{#each config.weaponTypes as |label key|}}
      <option value="{{key}}" {{selected ../system.weaponType key}}>{{localize label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Skill:</label>
    <input type="text" name="system.skill" value="{{system.skill}}" />
  </div>
  <div class="form-group">
    <label>Damage Code:</label>
    <input type="text" name="system.damageCode" value="{{system.damageCode}}" placeholder="e.g., 6M" />
  </div>
  <div class="form-group">
    <label>Damage Type:</label>
    <select name="system.damageType">
      <option value="physical" {{selected system.damageType "physical"}}>Physical</option>
      <option value="stun" {{selected system.damageType "stun"}}>Stun</option>
    </select>
  </div>
  <div class="form-group">
    <label title="Area weapons (grenades, rockets, missiles) resolve as a blast: Power falls off with distance and every token in the radius resists.">Blast (area):</label>
    <select name="system.blastType">
      <option value="" {{selected system.blastType ""}}>— None (single target)</option>
      <option value="offensive" {{selected system.blastType "offensive"}}>Offensive (−1/m)</option>
      <option value="defensive" {{selected system.blastType "defensive"}}>Defensive (−2/m)</option>
      <option value="concussion" {{selected system.blastType "concussion"}}>Concussion (−1/m, stun)</option>
    </select>
  </div>
  <div class="form-group">
    <label>Concealability:</label>
    <input type="number" name="system.concealability" value="{{system.concealability}}" />
  </div>
  <div class="form-group">
    <label>Reach:</label>
    <input type="number" name="system.reach" value="{{system.reach}}" min="0" />
  </div>

  {{!-- Firearm-specific fields --}}
  {{#ifEquals system.weaponType "firearm"}}
  <fieldset>
    <legend>Firing Modes</legend>
    <label><input type="checkbox" name="system.firingModes.ss" {{checked system.firingModes.ss}} /> SS</label>
    <label><input type="checkbox" name="system.firingModes.sa" {{checked system.firingModes.sa}} /> SA</label>
    <label><input type="checkbox" name="system.firingModes.bf" {{checked system.firingModes.bf}} /> BF</label>
    <label><input type="checkbox" name="system.firingModes.fa" {{checked system.firingModes.fa}} /> FA</label>
  </fieldset>
  <div class="form-group">
    <label>Ammo (Current/Max):</label>
    <input type="number" name="system.ammo.current" value="{{system.ammo.current}}" min="0" />
    <span>/</span>
    <input type="number" name="system.ammo.max" value="{{system.ammo.max}}" min="0" />
  </div>
  <div class="form-group">
    <label>Recoil Compensation:</label>
    <input type="number" name="system.recoilComp" value="{{system.recoilComp}}" min="0" />
  </div>
  <div class="form-group">
    <label>Smartgun Compatible:</label>
    <input type="checkbox" name="system.smartgunCompatible" {{checked system.smartgunCompatible}} />
  </div>
  <fieldset>
    <legend>Ranges</legend>
    <div class="flexrow">
      <div class="form-group"><label>Short:</label><input type="number" name="system.ranges.short" value="{{system.ranges.short}}" /></div>
      <div class="form-group"><label>Medium:</label><input type="number" name="system.ranges.medium" value="{{system.ranges.medium}}" /></div>
      <div class="form-group"><label>Long:</label><input type="number" name="system.ranges.long" value="{{system.ranges.long}}" /></div>
      <div class="form-group"><label>Extreme:</label><input type="number" name="system.ranges.extreme" value="{{system.ranges.extreme}}" /></div>
    </div>
  </fieldset>
  {{/ifEquals}}

  <div class="form-group">
    <label>Cost:</label>
    <input type="number" name="system.cost" value="{{system.cost}}" />
  </div>
  <div class="form-group">
    <label>Weight:</label>
    <input type="number" name="system.weight" value="{{system.weight}}" step="0.1" />
  </div>
  <div class="form-group">
    <label>Availability:</label>
    <input type="text" name="system.availability" value="{{system.availability}}" />
  </div>
  <div class="form-group">
    <label>Legality:</label>
    <input type="text" name="system.legality" value="{{system.legality}}" />
  </div>
  {{/ifEquals}}

  {{!-- ARMOR --}}
  {{#ifEquals type "armor"}}
  <div class="form-group">
    <label>Ballistic:</label>
    <input type="number" name="system.ballistic" value="{{system.ballistic}}" min="0" />
  </div>
  <div class="form-group">
    <label>Impact:</label>
    <input type="number" name="system.impact" value="{{system.impact}}" min="0" />
  </div>
  <div class="form-group">
    <label>Concealability:</label>
    <input type="number" name="system.concealability" value="{{system.concealability}}" />
  </div>
  <div class="form-group">
    <label>Cost:</label>
    <input type="number" name="system.cost" value="{{system.cost}}" />
  </div>
  <div class="form-group">
    <label>Equipped:</label>
    <input type="checkbox" name="system.equipped" {{checked system.equipped}} />
  </div>
  {{/ifEquals}}

  {{!-- SPELL --}}
  {{#ifEquals type "spell"}}
  <div class="form-group">
    <label>Category:</label>
    <select name="system.category">
      {{#each config.spellCategories as |label key|}}
      <option value="{{key}}" {{selected ../system.category key}}>{{localize label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Type:</label>
    <select name="system.type">
      <option value="physical" {{selected system.type "physical"}}>Physical</option>
      <option value="mana" {{selected system.type "mana"}}>Mana</option>
    </select>
  </div>
  <div class="form-group">
    <label>Range:</label>
    <select name="system.range">
      {{#each config.spellRanges as |label key|}}
      <option value="{{key}}" {{selected ../system.range key}}>{{localize label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Duration:</label>
    <select name="system.duration">
      {{#each config.spellDurations as |label key|}}
      <option value="{{key}}" {{selected ../system.duration key}}>{{localize label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Force:</label>
    <input type="number" name="system.force" value="{{system.force}}" min="1" />
  </div>
  <div class="form-group">
    <label>Drain Code:</label>
    <input type="text" name="system.drainCode" value="{{system.drainCode}}" placeholder="e.g., ((F / 2) + 1)M" />
  </div>
  <div class="form-group">
    <label>Target:</label>
    <input type="text" name="system.target" value="{{system.target}}" />
  </div>
  <div class="form-group">
    <label>Damage Code:</label>
    <input type="text" name="system.damageCode" value="{{system.damageCode}}" placeholder="For combat spells" />
  </div>
  <div class="form-group">
    <label>Area Effect:</label>
    <input type="checkbox" name="system.isAreaEffect" {{checked system.isAreaEffect}} />
  </div>
  <div class="form-group notes">
    <label>Description:</label>
    <textarea name="system.notes">{{system.notes}}</textarea>
  </div>

  {{!-- Active Effects applied to the caster while the spell is sustained.
        Useful keys: system.<attr>.mod, system.reaction.mod,
        system.initiative.mod (extra init dice), system.armor.ballistic/impact --}}
  <div class="form-group">
    <label>Sustained Effects:</label>
    <a data-action="addEffect" title="Add an Active Effect applied to the caster while this spell is sustained">
      <i class="fas fa-plus"></i> Add
    </a>
  </div>
  {{#each effects as |effect|}}
  <div class="form-group item-effect-row" data-effect-id="{{effect.id}}">
    <img src="{{effect.img}}" width="18" height="18" style="border:none;" />
    <span style="flex:1;">{{effect.name}}</span>
    <a data-action="editEffect" title="Edit"><i class="fas fa-edit"></i></a>
    <a data-action="deleteEffect" title="Delete"><i class="fas fa-trash"></i></a>
  </div>
  {{/each}}
  {{/ifEquals}}

  {{!-- CYBERWARE --}}
  {{#ifEquals type "cyberware"}}
  <div class="form-group">
    <label>Location:</label>
    <select name="system.location">
      {{#each config.cyberwareLocations as |label key|}}
      <option value="{{key}}" {{selected ../system.location key}}>{{localize label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Grade:</label>
    <select name="system.grade">
      {{#each config.cyberwareGrades as |grade key|}}
      <option value="{{key}}" {{selected ../system.grade key}}>{{localize grade.label}}</option>
      {{/each}}
    </select>
  </div>

  {{!-- Rating: dropdown from table tiers (if tiered) or plain number input --}}
  <div class="form-group">
    <label>Rating:</label>
    {{#if hasRatingTable}}
    <select name="system.rating">
      {{#each system.ratingStats}}
      <option value="{{this.rating}}" {{selected ../system.rating this.rating}}>{{this.rating}}</option>
      {{/each}}
    </select>
    {{else}}
    <input type="number" name="system.rating" value="{{system.rating}}" min="0" />
    {{/if}}
  </div>

  {{!-- Flat fields: only shown when there is NO rating table --}}
  {{#unless hasRatingTable}}
  <div class="form-group">
    <label>Essence Cost:</label>
    <input type="number" name="system.essenceCost" value="{{system.essenceCost}}" min="0" step="0.1" />
    {{#ifEquals system.grade "alpha"}}
    <span class="hint">(Actual: {{system.actualEssenceCost}})</span>
    {{/ifEquals}}
  </div>
  <div class="form-group">
    <label>Cost (¥):</label>
    <input type="number" name="system.cost" value="{{system.cost}}" />
  </div>
  <div class="form-group">
    <label>Availability:</label>
    <input type="text" name="system.availability" value="{{system.availability}}" />
  </div>
  <div class="form-group">
    <label>Street Index:</label>
    <input type="text" name="system.streetIndex" value="{{system.streetIndex}}" />
  </div>
  {{/unless}}

  <div class="form-group">
    <label>Installed:</label>
    <input type="checkbox" name="system.installed" {{checked system.installed}} />
  </div>
  <div class="form-group">
    <label>Combat TN Modifier:</label>
    <input type="number" name="system.combatTnMod" value="{{system.combatTnMod}}" />
    <span class="hint">(e.g. −1 for Smartlink; applies to compatible weapons only)</span>
  </div>
  <div class="form-group">
    <label>Vehicle Control Rig:</label>
    <input type="checkbox" name="system.isVcr" {{checked system.isVcr}} />
    <span class="hint">(when installed, this item's Rating sets the character's VCR level)</span>
  </div>

  {{!-- Per-rating stats table --}}
  {{#if hasRatingTable}}
  <div class="rating-stats-section">
    <div class="rating-stats-header">
      <span>Per-Rating Stats</span>
      {{#ifEquals system.grade "alpha"}}
      <span class="hint">— Actual Essence at Rating {{system.rating}}: {{system.actualEssenceCost}}</span>
      {{/ifEquals}}
    </div>
    <table class="rating-stats-table">
      <thead>
        <tr>
          <th>Rating</th>
          <th>Essence</th>
          <th>Cost (¥)</th>
          <th>Avail</th>
          <th>Street Index</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#each system.ratingStats}}
        <tr class="{{#ifEquals ../system.rating this.rating}}active-rating-row{{/ifEquals}}">
          <td><input type="number" name="system.ratingStats.{{@index}}.rating"       value="{{this.rating}}"       min="1" /></td>
          <td><input type="number" name="system.ratingStats.{{@index}}.essenceCost"   value="{{this.essenceCost}}"  min="0" step="0.1" /></td>
          <td><input type="number" name="system.ratingStats.{{@index}}.cost"          value="{{this.cost}}"         min="0" /></td>
          <td><input type="text"   name="system.ratingStats.{{@index}}.availability"  value="{{this.availability}}"  /></td>
          <td><input type="text"   name="system.ratingStats.{{@index}}.streetIndex"   value="{{this.streetIndex}}"   /></td>
          <td>
            <button type="button" class="remove-row-btn" data-action="removeRatingRow" data-index="{{@index}}" title="Remove row">
              <i class="fas fa-times"></i>
            </button>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  <div class="rating-stats-add">
    <button type="button" class="add-rating-row-btn" data-action="addRatingRow">
      <i class="fas fa-plus"></i>
      {{#if hasRatingTable}}Add Rating Row{{else}}Enable Rating Table{{/if}}
    </button>
  </div>

  {{!-- Container cyberware (cybereyes / cyberears): add-on modules + free capacity --}}
  {{#if isContainer}}
  <div class="form-group">
    <label>Module Capacity (Essence):</label>
    <input type="number" name="system.capacity" value="{{system.capacity}}" min="0" step="0.1" />
    <span class="hint">free Essence for add-on modules (0.5 for cybereyes)</span>
  </div>
  <div class="rating-stats-section">
    <div class="rating-stats-header">
      <span>Modules</span>
      <span class="hint">— capacity used {{system.capacityUsed}} / {{system.capacity}}{{#ifGt system.capacityOver 0}} · <strong>+{{system.capacityOver}}</strong> Essence over (total {{system.actualEssenceCost}}){{/ifGt}}</span>
    </div>
    <table class="rating-stats-table modules-table">
      <thead>
        <tr><th title="Installed / active">On</th><th>Module</th><th>Ess</th><th>Cost ¥</th><th>Rtg</th><th title="Combat TN modifier (e.g. −2 Smartlink)">TN</th><th></th></tr>
      </thead>
      <tbody>
        {{#each system.modules}}
        <tr class="{{#unless this.active}}inactive-row{{/unless}}">
          <td class="cb-cell"><label class="modules-cb"><input type="checkbox" name="system.modules.{{@index}}.active" {{checked this.active}} /></label></td>
          <td><input type="text"   name="system.modules.{{@index}}.name"        value="{{this.name}}" /></td>
          <td><input type="number" name="system.modules.{{@index}}.essenceCost" value="{{this.essenceCost}}" min="0" step="0.1" /></td>
          <td><input type="number" name="system.modules.{{@index}}.cost"        value="{{this.cost}}" min="0" /></td>
          <td><input type="number" name="system.modules.{{@index}}.rating"      value="{{this.rating}}" min="0" /></td>
          <td><input type="number" name="system.modules.{{@index}}.combatTnMod" value="{{this.combatTnMod}}" /></td>
          <td>
            <button type="button" class="remove-row-btn" data-action="removeModuleRow" data-index="{{@index}}" title="Remove module">
              <i class="fas fa-times"></i>
            </button>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}

  <div class="rating-stats-add">
    <button type="button" class="add-rating-row-btn" data-action="addModuleRow">
      <i class="fas fa-plus"></i>
      {{#if isContainer}}Add Module{{else}}Enable Modules (Cybereyes/ears){{/if}}
    </button>
  </div>

  <fieldset>
    <legend>Attribute Modifiers</legend>
    <div class="attr-mods-grid">
      <div class="form-group"><label>Body:</label><input type="number" name="system.attributeMods.body" value="{{system.attributeMods.body}}" /></div>
      <div class="form-group"><label>Quickness:</label><input type="number" name="system.attributeMods.quickness" value="{{system.attributeMods.quickness}}" /></div>
      <div class="form-group"><label>Strength:</label><input type="number" name="system.attributeMods.strength" value="{{system.attributeMods.strength}}" /></div>
      <div class="form-group"><label>Reaction:</label><input type="number" name="system.attributeMods.reaction" value="{{system.attributeMods.reaction}}" /></div>
      <div class="form-group"><label>Init Dice:</label><input type="number" name="system.attributeMods.initiativeDice" value="{{system.attributeMods.initiativeDice}}" /></div>
    </div>
  </fieldset>
  {{/ifEquals}}

  {{!-- PROGRAM --}}
  {{#ifEquals type "program"}}
  <div class="form-group">
    <label>Category:</label>
    <select name="system.category">
      {{#each config.programCategories as |label key|}}
      <option value="{{key}}" {{selected ../system.category key}}>{{localize label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Rating:</label>
    <input type="number" name="system.rating" value="{{system.rating}}" min="1" />
  </div>
  <div class="form-group">
    <label>Multiplier:</label>
    <input type="number" name="system.multiplier" value="{{system.multiplier}}" min="0" step="0.1" />
  </div>
  <div class="form-group">
    <label>Size (MP):</label>
    <span>{{system.size}}</span>
  </div>
  <div class="form-group">
    <label>Cost:</label>
    <span>{{system.cost}}¥ <em style="opacity:.6;">(Size × 100)</em></span>
  </div>
  <div class="form-group">
    <label>Loaded:</label>
    <input type="checkbox" name="system.loaded" {{checked system.loaded}} />
  </div>
  {{/ifEquals}}

  {{!-- GEAR --}}
  {{#ifEquals type "gear"}}
  <div class="form-group">
    <label>Category:</label>
    <input type="text" name="system.category" value="{{system.category}}" />
  </div>
  <div class="form-group">
    <label>Rating:</label>
    <input type="number" name="system.rating" value="{{system.rating}}" min="0" />
  </div>
  <div class="form-group">
    <label>Quantity:</label>
    <input type="number" name="system.quantity" value="{{system.quantity}}" min="0" />
  </div>
  <div class="form-group">
    <label>Cost:</label>
    <input type="number" name="system.cost" value="{{system.cost}}" />
  </div>
  <div class="form-group">
    <label>Equipped:</label>
    <input type="checkbox" name="system.equipped" {{checked system.equipped}} />
  </div>
  <div class="form-group">
    <label>Weapon Accessory:</label>
    <input type="checkbox" name="system.weaponAccessory" {{checked system.weaponAccessory}}
           title="Mark this as a weapon mod (Laser Sight, Smartgun System, Gas-vent, Gyro Mount, etc.) that attaches to one weapon." />
  </div>
  {{#if system.weaponAccessory}}
  <div class="form-group">
    <label>Attack TN Mod:</label>
    <input type="number" name="system.combatTnMod" value="{{system.combatTnMod}}"
           title="Modifier to the attached weapon's attack TN (e.g. Laser Sight −1, Smartgun System −2)." />
  </div>
  <div class="form-group">
    <label>Recoil Comp:</label>
    <input type="number" name="system.accessoryRecoilComp" value="{{system.accessoryRecoilComp}}" min="0"
           title="Recoil compensation the accessory grants the attached weapon (Gas-vent, Gyro Mount, Bipod)." />
  </div>
  <div class="form-group">
    <label>Requires Smartgun:</label>
    <input type="checkbox" name="system.requiresSmartgun" {{checked system.requiresSmartgun}}
           title="Only applies on a smartgun-compatible weapon (Smartgun System)." />
  </div>
  {{/if}}
  {{#ifEquals system.category "skillsoft"}}
  <hr/>
  <p class="hint">Skillsoft — slot it on the Gear tab to grant the skill below at this Rating (SR2E p.243).</p>
  <div class="form-group">
    <label>Skill Type:</label>
    <select name="system.grantedSkillCategory">
      <option value="active"    {{selected system.grantedSkillCategory "active"}}>Active (ActiveSoft — needs Skillwires)</option>
      <option value="knowledge" {{selected system.grantedSkillCategory "knowledge"}}>Knowledge (KnowSoft)</option>
      <option value="language"  {{selected system.grantedSkillCategory "language"}}>Language (LinguaSoft)</option>
    </select>
  </div>
  <div class="form-group">
    <label>Quick Pick:</label>
    <select class="skill-picker" title="Pick a standard skill to fill in the fields below; auto-sets the linked attribute and names the chip.">
      <option value="">— standard skills —</option>
      {{#each skillCatalog as |s|}}
      <option value="{{s.name}}" data-attr="{{s.attribute}}">{{s.name}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Granted Skill:</label>
    <input type="text" name="system.grantedSkill" value="{{system.grantedSkill}}"
           placeholder="e.g. Firearms (or a custom Knowledge/Language)"
           title="The skill this soft provides. If the character already has it, the soft's rating replaces it while slotted." />
  </div>
  <div class="form-group">
    <label>Linked Attribute:</label>
    <input type="text" name="system.grantedSkillAttribute" value="{{system.grantedSkillAttribute}}" placeholder="intelligence" />
  </div>
  <p class="hint">Set <em>Skill Type</em> first, then use <em>Quick Pick</em> for standard skills — or type a custom Knowledge/Language skill. Set the Rating above.</p>
  {{/ifEquals}}
  {{/ifEquals}}

  {{!-- ADEPT POWER --}}
  {{#ifEquals type "adept_power"}}
  <div class="form-group">
    <label>Point Cost (per level):</label>
    <input type="number" name="system.pointCost" value="{{system.pointCost}}" min="0" step="0.25" />
  </div>
  <div class="form-group">
    <label>Level:</label>
    <input type="number" name="system.level" value="{{system.level}}" min="1" max="{{system.maxLevel}}" />
  </div>
  <div class="form-group">
    <label>Max Level:</label>
    <input type="number" name="system.maxLevel" value="{{system.maxLevel}}" min="1" />
  </div>
  <div class="form-group">
    <label>Total Cost:</label>
    <span>{{system.totalCost}}</span>
  </div>
  <fieldset>
    <legend>Attribute Modifiers</legend>
    <div class="form-group"><label>Body:</label><input type="number" name="system.attributeMods.body" value="{{system.attributeMods.body}}" /></div>
    <div class="form-group"><label>Quickness:</label><input type="number" name="system.attributeMods.quickness" value="{{system.attributeMods.quickness}}" /></div>
    <div class="form-group"><label>Strength:</label><input type="number" name="system.attributeMods.strength" value="{{system.attributeMods.strength}}" /></div>
    <div class="form-group"><label>Reaction:</label><input type="number" name="system.attributeMods.reaction" value="{{system.attributeMods.reaction}}" /></div>
  </fieldset>
  {{/ifEquals}}

  {{!-- CONTACT --}}
  {{#ifEquals type "contact"}}
  <div class="form-group">
    <label>Type:</label>
    <select name="system.contactType">
      <option value="contact" {{selected system.contactType "contact"}}>Contact</option>
      <option value="buddy" {{selected system.contactType "buddy"}}>Buddy</option>
      <option value="friend" {{selected system.contactType "friend"}}>Friend For Life</option>
      <option value="follower" {{selected system.contactType "follower"}}>Follower</option>
      <option value="enemy" {{selected system.contactType "enemy"}}>Enemy</option>
    </select>
  </div>
  <div class="form-group">
    <label>Archetype:</label>
    <input type="text" name="system.archetype" value="{{system.archetype}}" />
  </div>
  <div class="form-group">
    <label>Loyalty:</label>
    <input type="number" name="system.loyalty" value="{{system.loyalty}}" min="1" max="6" />
  </div>
  <div class="form-group">
    <label>Influence:</label>
    <input type="number" name="system.influence" value="{{system.influence}}" min="1" max="6" />
  </div>
  {{/ifEquals}}

  {{!-- LIFESTYLE --}}
  {{#ifEquals type "lifestyle"}}
  <div class="form-group">
    <label>Level:</label>
    <select name="system.level">
      {{#each config.lifestyles as |ls key|}}
      <option value="{{key}}" {{selected ../system.level key}}>{{localize ls.label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Monthly Cost:</label>
    <span>{{system.monthlyCost}}¥</span>
  </div>
  <div class="form-group">
    <label>Months Paid:</label>
    <input type="number" name="system.monthsPaid" value="{{system.monthsPaid}}" min="0" />
  </div>
  {{/ifEquals}}

  {{!-- FOCUS --}}
  {{#ifEquals type "focus"}}
  <div class="form-group">
    <label>Focus Type:</label>
    <select name="system.focusType">
      <option value="spell" {{selected system.focusType "spell"}}>Spell Focus</option>
      <option value="spirit" {{selected system.focusType "spirit"}}>Spirit Focus</option>
      <option value="power" {{selected system.focusType "power"}}>Power Focus</option>
      <option value="weapon" {{selected system.focusType "weapon"}}>Weapon Focus</option>
      <option value="spell_lock" {{selected system.focusType "spell_lock"}}>Spell Lock</option>
    </select>
  </div>
  <div class="form-group">
    <label>Force:</label>
    <input type="number" name="system.force" value="{{system.force}}" min="1" />
  </div>
  <div class="form-group">
    <label>Bonding Cost (Karma):</label>
    <input type="number" name="system.bondingCost" value="{{system.bondingCost}}" min="1" />
  </div>
  <div class="form-group">
    <label>Bonded:</label>
    <input type="checkbox" name="system.bonded" {{checked system.bonded}} />
  </div>
  <div class="form-group">
    <label>Active:</label>
    <input type="checkbox" name="system.active" {{checked system.active}} />
  </div>
  <div class="form-group">
    <label>Cost:</label>
    {{#if system.costPerForce}}
    <span>{{system.cost}}¥ <em style="opacity:.6;">(Force × {{system.costPerForce}})</em></span>
    {{else}}
    <input type="number" name="system.cost" value="{{system.cost}}" />
    {{/if}}
  </div>
  {{/ifEquals}}

  {{!-- AMMO --}}
  {{#ifEquals type "ammo"}}
  <div class="form-group">
    <label>Ammo Type:</label>
    <input type="text" name="system.ammoType" value="{{system.ammoType}}" />
  </div>
  <div class="form-group">
    <label>Quantity:</label>
    <input type="number" name="system.quantity" value="{{system.quantity}}" min="0" />
  </div>
  <div class="form-group">
    <label>Power Modifier:</label>
    <input type="number" name="system.damageModifier" value="{{system.damageModifier}}"
           title="Added to the weapon's Damage Power on attack (explosive +1, gel −2)" />
  </div>
  <div class="form-group">
    <label>Damage Type:</label>
    <select name="system.damageType"
            title="Overrides the weapon's damage type when set (gel rounds → Stun)">
      <option value="" {{selected system.damageType ""}}>Weapon default</option>
      <option value="physical" {{selected system.damageType "physical"}}>Physical</option>
      <option value="stun" {{selected system.damageType "stun"}}>Stun</option>
    </select>
  </div>
  <div class="form-group">
    <label>Armor Calculation:</label>
    <select name="system.armorCalc"
            title="How the defender's armor is computed (SR2E p.93–94)">
      <option value="standard" {{selected system.armorCalc "standard"}}>Standard</option>
      <option value="half_ballistic" {{selected system.armorCalc "half_ballistic"}}>½ Ballistic (APDS)</option>
      <option value="impact" {{selected system.armorCalc "impact"}}>Impact applies (Gel)</option>
      <option value="flechette" {{selected system.armorCalc "flechette"}}>max(2×Impact, Ballistic) (Flechette)</option>
    </select>
  </div>
  <div class="form-group">
    <label>Armor Modifier:</label>
    <input type="number" name="system.armorModifier" value="{{system.armorModifier}}"
           title="Flat adjustment to the computed armor rating (negative = armor-piercing)" />
  </div>
  <div class="form-group">
    <label>Cost:</label>
    <input type="number" name="system.cost" value="{{system.cost}}" />
  </div>
  {{/ifEquals}}

  {{!-- RACE / METATYPE --}}
  {{#ifEquals type "race"}}
  <div class="form-group">
    <label>Race Key:</label>
    <select name="system.raceKey">
      {{#each config.races as |label key|}}
      <option value="{{key}}" {{selected ../system.raceKey key}}>{{localize label}}</option>
      {{/each}}
    </select>
  </div>
  <fieldset>
    <legend>Attribute Modifiers</legend>
    <div class="attr-mods-grid">
      <div class="form-group"><label>Body:</label><input type="number" name="system.attributeMods.body" value="{{system.attributeMods.body}}" /></div>
      <div class="form-group"><label>Quickness:</label><input type="number" name="system.attributeMods.quickness" value="{{system.attributeMods.quickness}}" /></div>
      <div class="form-group"><label>Strength:</label><input type="number" name="system.attributeMods.strength" value="{{system.attributeMods.strength}}" /></div>
      <div class="form-group"><label>Charisma:</label><input type="number" name="system.attributeMods.charisma" value="{{system.attributeMods.charisma}}" /></div>
      <div class="form-group"><label>Intelligence:</label><input type="number" name="system.attributeMods.intelligence" value="{{system.attributeMods.intelligence}}" /></div>
      <div class="form-group"><label>Willpower:</label><input type="number" name="system.attributeMods.willpower" value="{{system.attributeMods.willpower}}" /></div>
    </div>
  </fieldset>
  <fieldset>
    <legend>Attribute Maximums</legend>
    <div class="attr-mods-grid">
      <div class="form-group"><label>Body:</label><input type="number" name="system.attributeMaximums.body" value="{{system.attributeMaximums.body}}" min="1" /></div>
      <div class="form-group"><label>Quickness:</label><input type="number" name="system.attributeMaximums.quickness" value="{{system.attributeMaximums.quickness}}" min="1" /></div>
      <div class="form-group"><label>Strength:</label><input type="number" name="system.attributeMaximums.strength" value="{{system.attributeMaximums.strength}}" min="1" /></div>
      <div class="form-group"><label>Charisma:</label><input type="number" name="system.attributeMaximums.charisma" value="{{system.attributeMaximums.charisma}}" min="1" /></div>
      <div class="form-group"><label>Intelligence:</label><input type="number" name="system.attributeMaximums.intelligence" value="{{system.attributeMaximums.intelligence}}" min="1" /></div>
      <div class="form-group"><label>Willpower:</label><input type="number" name="system.attributeMaximums.willpower" value="{{system.attributeMaximums.willpower}}" min="1" /></div>
      <div class="form-group"><label>Essence:</label><input type="number" name="system.attributeMaximums.essence" value="{{system.attributeMaximums.essence}}" min="0" step="0.01" /></div>
      <div class="form-group"><label>Magic:</label><input type="number" name="system.attributeMaximums.magic" value="{{system.attributeMaximums.magic}}" min="0" /></div>
      <div class="form-group"><label>Reaction:</label><input type="number" name="system.attributeMaximums.reaction" value="{{system.attributeMaximums.reaction}}" min="1" /></div>
    </div>
  </fieldset>
  <div class="form-group">
    <label>Karma Cost:</label>
    <input type="number" name="system.karmaCost" value="{{system.karmaCost}}" min="0" />
  </div>
  <div class="form-group">
    <label>Description:</label>
    <prose-mirror name="system.description">{{{system.description}}}</prose-mirror>
  </div>
  {{/ifEquals}}

  {{#ifEquals type "quality"}}
  <div class="form-group">
    <label>Kind:</label>
    <select name="system.kind">
      {{#each qualityKinds as |label key|}}<option value="{{key}}" {{selected ../system.kind key}}>{{localize label}}</option>{{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Category:</label>
    <select name="system.category">
      {{#each qualityCategories as |label key|}}<option value="{{key}}" {{selected ../system.category key}}>{{localize label}}</option>{{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Point Value:</label>
    <input type="number" name="system.pointValue" value="{{system.pointValue}}" step="1" />
    <span class="hint">Edges positive, Flaws negative (tiers noted below).</span>
  </div>
  <div class="form-group">
    <label>Source:</label>
    <input type="text" name="system.source" value="{{system.source}}" placeholder="e.g. Rigger 2 p.15" />
  </div>
  {{/ifEquals}}

  {{!-- Notes (common to all non-race items) --}}
  {{#ifEquals type "skill"}}    <div class="form-group notes"><label>Notes:</label><textarea name="system.notes">{{system.notes}}</textarea></div>{{/ifEquals}}
  {{#ifEquals type "quality"}}  <div class="form-group notes"><label>Notes:</label><textarea name="system.notes">{{system.notes}}</textarea></div>{{/ifEquals}}
  {{#ifEquals type "weapon"}}   <div class="form-group notes"><label>Notes:</label><textarea name="system.notes">{{system.notes}}</textarea></div>{{/ifEquals}}
  {{#ifEquals type "armor"}}    <div class="form-group notes"><label>Notes:</label><textarea name="system.notes">{{system.notes}}</textarea></div>{{/ifEquals}}
  {{#ifEquals type "cyberware"}}<div class="form-group notes"><label>Notes:</label><textarea name="system.notes">{{system.notes}}</textarea></div>{{/ifEquals}}
  {{#ifEquals type "program"}}  <div class="form-group notes"><label>Notes:</label><textarea name="system.notes">{{system.notes}}</textarea></div>{{/ifEquals}}
  {{#ifEquals type "gear"}}     <div class="form-group notes"><label>Notes:</label><textarea name="system.notes">{{system.notes}}</textarea></div>{{/ifEquals}}
  {{#ifEquals type "focus"}}    <div class="form-group notes"><label>Notes:</label><textarea name="system.notes">{{system.notes}}</textarea></div>{{/ifEquals}}
  {{#ifEquals type "ammo"}}     <div class="form-group notes"><label>Notes:</label><textarea name="system.notes">{{system.notes}}</textarea></div>{{/ifEquals}}
  {{#ifEquals type "vehicle_mod"}}<div class="form-group notes"><label>Notes:</label><textarea name="system.notes">{{system.notes}}</textarea></div>{{/ifEquals}}

</section>
