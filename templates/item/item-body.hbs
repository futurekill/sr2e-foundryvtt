<section class="item-body">

  {{!-- SKILL --}}
  {{#ifEquals type "skill"}}
  <div class="form-group">
    <label>Category:</label>
    <select name="system.category">
      {{#each config.skillCategories as |label key|}}
      <option value="{{key}}" {{selected ../system.category key}}>{{localize label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Linked Attribute:</label>
    <select name="system.linkedAttribute">
      {{#each config.attributes as |label key|}}
      <option value="{{key}}" {{selected ../system.linkedAttribute key}}>{{localize label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Rating:</label>
    <input type="number" name="system.rating" value="{{system.rating}}" min="0" max="12" />
  </div>
  <div class="form-group">
    <label title="SR2E p.55/70. Enter the FINAL general rating above (already reduced by −1 for a concentration / −2 for a specialization); the concentration rolls general +2.">Concentration:</label>
    <input type="text" name="system.concentration.name" value="{{system.concentration.name}}" placeholder="e.g., Pistols" />
    {{#if system.concentration.name}}
    <span title="general + 2 (SR2E p.70)">Rating: {{system.concentration.rating}}</span>
    {{/if}}
  </div>
  <div class="form-group">
    <label title="SR2E p.55/70. Enter the FINAL general rating above (already reduced by −2); the specialization rolls general +4, and its concentration general +2. Name the concentration too — a specialization is a narrowing of one.">Specialization:</label>
    <input type="text" name="system.specialization.name" value="{{system.specialization.name}}" placeholder="e.g., Ares Predator" />
    {{#if system.specialization.name}}
    <span title="general + 4 (SR2E p.70)">Rating: {{system.specialization.rating}}</span>
    {{/if}}
  </div>
  <div class="form-group">
    <label>Magical Skill:</label>
    <input type="checkbox" name="system.isMagical" {{checked system.isMagical}} />
  </div>
  {{/ifEquals}}

  {{!-- WEAPON --}}
  {{#ifEquals type "weapon"}}
  <div class="form-group">
    <label>Weapon Type:</label>
    <select name="system.weaponType">
      {{#each config.weaponTypes as |label key|}}
      <option value="{{key}}" {{selected ../system.weaponType key}}>{{localize label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Skill:</label>
    <input type="text" name="system.skill" value="{{system.skill}}" />
  </div>
  <div class="form-group">
    <label>Damage Code:</label>
    <input type="text" name="system.damageCode" value="{{system.damageCode}}" placeholder="e.g., 6M" />
  </div>
  <div class="form-group">
    <label>Damage Type:</label>
    <select name="system.damageType">
      <option value="physical" {{selected system.damageType "physical"}}>Physical</option>
      <option value="stun" {{selected system.damageType "stun"}}>Stun</option>
    </select>
  </div>
  <div class="form-group">
    <label title="Area weapons (grenades, rockets, missiles) resolve as a blast: Power falls off with distance and every token in the radius resists.">Blast (area):</label>
    <select name="system.blastType">
      <option value="" {{selected system.blastType ""}}>— None (single target)</option>
      <option value="offensive" {{selected system.blastType "offensive"}}>Offensive (−1/m)</option>
      <option value="defensive" {{selected system.blastType "defensive"}}>Defensive (−2/m)</option>
      <option value="concussion" {{selected system.blastType "concussion"}}>Concussion (−1/m, stun)</option>
      <option value="smoke" {{selected system.blastType "smoke"}}>Smoke (no damage, drops a cloud)</option>
    </select>
  </div>
  <div class="form-group">
    <label>Concealability:</label>
    <input type="number" name="system.concealability" value="{{system.concealability}}" />
  </div>
  <div class="form-group">
    <label>Reach:</label>
    <input type="number" name="system.reach" value="{{system.reach}}" min="0" />
  </div>
  {{#if system._boundFocusName}}
  <div class="form-group">
    <label title="A Weapon Focus item is bonded to this weapon (SR2E p.126). Manage it on the Magic tab.">Weapon Focus:</label>
    <span class="focus-price">✦ {{system._boundFocusName}} (Force {{system._boundFocusForce}}){{#unless system._boundFocusActive}} — inactive{{/unless}}</span>
  </div>
  {{/if}}

  {{!-- Firearm-specific fields --}}
  {{#ifEquals system.weaponType "firearm"}}
  <fieldset>
    <legend>Firing Modes</legend>
    <label><input type="checkbox" name="system.firingModes.ss" {{checked system.firingModes.ss}} /> SS</label>
    <label><input type="checkbox" name="system.firingModes.sa" {{checked system.firingModes.sa}} /> SA</label>
    <label><input type="checkbox" name="system.firingModes.bf" {{checked system.firingModes.bf}} /> BF</label>
    <label><input type="checkbox" name="system.firingModes.fa" {{checked system.firingModes.fa}} /> FA</label>
  </fieldset>
  <div class="form-group">
    <label>Ammo (Current/Max):</label>
    <input type="number" name="system.ammo.current" value="{{system.ammo.current}}" min="0" />
    <span>/</span>
    <input type="number" name="system.ammo.max" value="{{system.ammo.max}}" min="0" />
  </div>
  <div class="form-group">
    <label>Recoil Compensation:</label>
    <input type="number" name="system.recoilComp" value="{{system.recoilComp}}" min="0" />
  </div>
  <div class="form-group">
    <label>Shotgun Choke:</label>
    <input type="number" name="system.choke" value="{{system.choke}}" min="0" max="10"
           title="0 = not a shotgun. 2–10 enables firing shot rounds, which spread into a cone (SR2E p.95). The higher the choke, the slower the spread." />
  </div>
  <div class="form-group">
    <label>Smartgun Compatible:</label>
    <input type="checkbox" name="system.smartgunCompatible" {{checked system.smartgunCompatible}} />
  </div>
  <fieldset>
    <legend>Ranges</legend>
    <div class="flexrow">
      <div class="form-group"><label>Short:</label><input type="number" name="system.ranges.short" value="{{system.ranges.short}}" /></div>
      <div class="form-group"><label>Medium:</label><input type="number" name="system.ranges.medium" value="{{system.ranges.medium}}" /></div>
      <div class="form-group"><label>Long:</label><input type="number" name="system.ranges.long" value="{{system.ranges.long}}" /></div>
      <div class="form-group"><label>Extreme:</label><input type="number" name="system.ranges.extreme" value="{{system.ranges.extreme}}" /></div>
    </div>
  </fieldset>
  {{/ifEquals}}

  <div class="form-group">
    <label>Cost:</label>
    <input type="number" name="system.cost" value="{{system.cost}}" />
  </div>
  <div class="form-group">
    <label title="Black-market price multiplier: street price = cost × SI. 1 = list price.">Street Index:</label>
    <input type="number" name="system.streetIndex" value="{{system.streetIndex}}" step="0.05" min="0" />
    <span class="price-base">street: {{priceTag system.cost system.streetIndex}}</span>
  </div>
  <div class="form-group">
    <label>Weight:</label>
    <input type="number" name="system.weight" value="{{system.weight}}" step="0.1" />
  </div>
  <div class="form-group">
    <label>Availability:</label>
    <input type="text" name="system.availability" value="{{system.availability}}" />
  </div>
  <div class="form-group">
    <label>Legality:</label>
    <input type="text" name="system.legality" value="{{system.legality}}" />
  </div>
  {{/ifEquals}}

  {{!-- ARMOR --}}
  {{#ifEquals type "armor"}}
  <div class="form-group">
    <label>Ballistic:</label>
    <input type="number" name="system.ballistic" value="{{system.ballistic}}" min="0" />
  </div>
  <div class="form-group">
    <label>Impact:</label>
    <input type="number" name="system.impact" value="{{system.impact}}" min="0" />
  </div>
  <div class="form-group">
    <label>Concealability:</label>
    <input type="number" name="system.concealability" value="{{system.concealability}}" />
  </div>
  <div class="form-group">
    <label>Cost:</label>
    <input type="number" name="system.cost" value="{{system.cost}}" />
  </div>
  <div class="form-group">
    <label title="Black-market price multiplier: street price = cost × SI. 1 = list price.">Street Index:</label>
    <input type="number" name="system.streetIndex" value="{{system.streetIndex}}" step="0.05" min="0" />
    <span class="price-base">street: {{priceTag system.cost system.streetIndex}}</span>
  </div>
  <div class="form-group">
    <label>Equipped:</label>
    <input type="checkbox" name="system.equipped" {{checked system.equipped}} />
  </div>
  <div class="form-group">
    <label>Layered:</label>
    <input type="checkbox" name="system.isLayered" {{checked system.isLayered}}
           title="Adds its rating to other worn armor instead of competing for highest — helmets (SR2E p.242) and form-fitting body armor." />
  </div>
  <div class="form-group">
    <label>Heavy Armor:</label>
    <input type="checkbox" name="system.heavyArmor" {{checked system.heavyArmor}}
           title="Partial/full heavy armor: reduces the Combat Pool by 1 die per point of Ballistic over the wearer's Quickness (SR2E p.84)." />
  </div>
  {{/ifEquals}}

  {{!-- SPELL --}}
  {{#ifEquals type "spell"}}
  <div class="form-group">
    <label>Category:</label>
    <select name="system.category">
      {{#each config.spellCategories as |label key|}}
      <option value="{{key}}" {{selected ../system.category key}}>{{localize label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Type:</label>
    <select name="system.type">
      <option value="physical" {{selected system.type "physical"}}>Physical</option>
      <option value="mana" {{selected system.type "mana"}}>Mana</option>
    </select>
  </div>
  <div class="form-group">
    <label>Range:</label>
    <select name="system.range">
      {{#each config.spellRanges as |label key|}}
      <option value="{{key}}" {{selected ../system.range key}}>{{localize label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Duration:</label>
    <select name="system.duration">
      {{#each config.spellDurations as |label key|}}
      <option value="{{key}}" {{selected ../system.duration key}}>{{localize label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Force:</label>
    <input type="number" name="system.force" value="{{system.force}}" min="1" />
  </div>
  <div class="form-group">
    <label>Drain Code:</label>
    <input type="text" name="system.drainCode" value="{{system.drainCode}}" placeholder="e.g., ((F / 2) + 1)M" />
  </div>
  <div class="form-group">
    <label>Target:</label>
    <input type="text" name="system.target" value="{{system.target}}" />
  </div>
  <div class="form-group">
    <label>Damage Code:</label>
    <input type="text" name="system.damageCode" value="{{system.damageCode}}" placeholder="For combat spells" />
  </div>
  <div class="form-group">
    <label>Area Effect:</label>
    <input type="checkbox" name="system.isAreaEffect" {{checked system.isAreaEffect}} />
  </div>
  <div class="form-group">
    <label title="Magical healing takes +½ the subject's Body Index to its TN (Shadowtech p.6).">Heals Damage:</label>
    <input type="checkbox" name="system.healsDamage" {{checked system.healsDamage}} />
  </div>
  <div class="form-group notes">
    <label>Description:</label>
    <textarea name="system.notes">{{system.notes}}</textarea>
  </div>

  {{!-- Active Effects applied to the caster while the spell is sustained.
        Useful keys: system.<attr>.mod, system.reaction.mod,
        system.initiative.mod (extra init dice), system.armor.ballistic/impact --}}
  <div class="form-group">
    <label>Sustained Effects:</label>
    <a data-action="addEffect" title="Add an Active Effect applied to the caster while this spell is sustained">
      <i class="fas fa-plus"></i> Add
    </a>
  </div>
  {{#each effects as |effect|}}
  <div class="form-group item-effect-row" data-effect-id="{{effect.id}}">
    <img src="{{effect.img}}" width="18" height="18" style="border:none;" />
    <span style="flex:1;">{{effect.name}}</span>
    <a data-action="editEffect" title="Edit"><i class="fas fa-edit"></i></a>
    <a data-action="deleteEffect" title="Delete"><i class="fas fa-trash"></i></a>
  </div>
  {{/each}}
  {{/ifEquals}}

  {{!-- CYBERWARE --}}
  {{#ifEquals type "bioware"}}
  <div class="form-group">
    <label>Body System:</label>
    <select name="system.bodySystem">
      {{#each config.bodySystems as |label key|}}
      <option value="{{key}}" {{selected ../system.bodySystem key}}>{{localize label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Grade:</label>
    <select name="system.grade">
      {{#each config.biowareGrades as |grade key|}}
      <option value="{{key}}" {{selected ../system.grade key}}>{{localize grade.label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Rating:</label>
    {{#if hasRatingTable}}
    <select name="system.rating">
      {{#each system.ratingStats}}
      <option value="{{this.rating}}" {{selected ../system.rating this.rating}}>{{this.rating}}</option>
      {{/each}}
    </select>
    {{else}}
    <input type="number" name="system.rating" value="{{system.rating}}" min="0" />
    {{/if}}
  </div>

  {{#unless hasRatingTable}}
  <div class="form-group">
    <label>Body Cost:</label>
    <input type="number" name="system.bodyCost" value="{{system.bodyCost}}" min="0" step="0.05" />
    {{#ifEquals system.grade "cultured"}}
    <span class="hint">(Cultured — actual: {{formatEssence system.actualBodyCost}})</span>
    {{/ifEquals}}
  </div>
  <div class="form-group">
    <label>Cost (¥):</label>
    <input type="number" name="system.cost" value="{{system.cost}}" />
  </div>
  <div class="form-group">
    <label>Availability:</label>
    <input type="text" name="system.availability" value="{{system.availability}}" />
  </div>
  <div class="form-group">
    <label>Street Index:</label>
    <input type="text" name="system.streetIndex" value="{{system.streetIndex}}" />
  </div>
  <div class="form-group">
    <label title="Subdermal armor (Orthoskin) — adds to worn armor">Armor (Ball / Imp):</label>
    <input type="number" name="system.armorBallistic" value="{{system.armorBallistic}}" min="0" style="width:3em" />
    <input type="number" name="system.armorImpact" value="{{system.armorImpact}}" min="0" style="width:3em" />
  </div>
  {{/unless}}

  {{#if hasRatingTable}}
  <div class="rating-stats-section">
    <div class="rating-stats-header">
      <span>Per-Rating Stats</span>
      {{#ifEquals system.grade "cultured"}}
      <span class="hint">— Actual Body Cost at Rating {{system.rating}}: {{formatEssence system.actualBodyCost}}</span>
      {{/ifEquals}}
    </div>
    <table class="rating-stats-table">
      <thead>
        <tr><th>Rating</th><th>Body Cost</th><th>Cost (¥)</th><th>Avail</th><th>Street Index</th><th title="Subdermal armor at this rating">Arm B/I</th><th></th></tr>
      </thead>
      <tbody>
        {{#each system.ratingStats}}
        <tr class="{{#ifEquals ../system.rating this.rating}}active-rating-row{{/ifEquals}}">
          <td><input type="number" name="system.ratingStats.{{@index}}.rating"      value="{{this.rating}}"      min="1" /></td>
          <td><input type="number" name="system.ratingStats.{{@index}}.bodyCost"    value="{{this.bodyCost}}"    min="0" step="0.05" /></td>
          <td><input type="number" name="system.ratingStats.{{@index}}.cost"        value="{{this.cost}}"        min="0" /></td>
          <td><input type="text"   name="system.ratingStats.{{@index}}.availability" value="{{this.availability}}" /></td>
          <td><input type="text"   name="system.ratingStats.{{@index}}.streetIndex"  value="{{this.streetIndex}}" /></td>
          <td><input type="number" name="system.ratingStats.{{@index}}.armorBallistic" value="{{this.armorBallistic}}" min="0" style="width:2.5em" /><input type="number" name="system.ratingStats.{{@index}}.armorImpact" value="{{this.armorImpact}}" min="0" style="width:2.5em" /></td>
          <td><button type="button" class="remove-row-btn" data-action="removeRatingRow" data-index="{{@index}}" title="Remove row"><i class="fas fa-times"></i></button></td>
        </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
  {{/if}}
  <div class="rating-stats-add">
    <button type="button" class="add-rating-row-btn" data-action="addRatingRow">
      <i class="fas fa-plus"></i>
      {{#if hasRatingTable}}Add Rating Row{{else}}Enable Rating Table{{/if}}
    </button>
  </div>

  <div class="form-group">
    <label>Installed:</label>
    <input type="checkbox" name="system.installed" {{checked system.installed}} />
  </div>
  <div class="form-group">
    <label title="Adrenal Pump, Pain Editor: mods apply only while activated">Triggered:</label>
    <input type="checkbox" name="system.triggered" {{checked system.triggered}} />
    <span class="hint">(bonuses apply only when activated via the ⚡ on the character sheet)</span>
  </div>
  <div class="form-group">
    <label title="Dice added to every Active Skill Success Test while installed — sheet skill rolls AND weapon attacks. Enhanced Articulation (Shadowtech p.34) is 1. Per Level, like the attribute mods. RAW this covers all Active Skills, which in SR2 includes Sorcery/Conjuring and the social skills. 0 = no effect.">Active Skill Dice:</label>
    <input type="number" name="system.activeSkillDice" value="{{system.activeSkillDice}}" min="0" />
  </div>

  <fieldset>
    <legend>Attribute Modifiers <span class="hint">— per Level (multiplied by Rating)</span></legend>
    <div class="attr-mods-grid">
      <div class="form-group"><label>Body:</label><input type="number" name="system.attributeMods.body" value="{{system.attributeMods.body}}" /></div>
      <div class="form-group"><label>Quickness:</label><input type="number" name="system.attributeMods.quickness" value="{{system.attributeMods.quickness}}" /></div>
      <div class="form-group"><label>Strength:</label><input type="number" name="system.attributeMods.strength" value="{{system.attributeMods.strength}}" /></div>
      <div class="form-group"><label>Charisma:</label><input type="number" name="system.attributeMods.charisma" value="{{system.attributeMods.charisma}}" /></div>
      <div class="form-group"><label>Intelligence:</label><input type="number" name="system.attributeMods.intelligence" value="{{system.attributeMods.intelligence}}" /></div>
      <div class="form-group"><label>Willpower:</label><input type="number" name="system.attributeMods.willpower" value="{{system.attributeMods.willpower}}" /></div>
      <div class="form-group"><label>Reaction:</label><input type="number" name="system.attributeMods.reaction" value="{{system.attributeMods.reaction}}" /></div>
      <div class="form-group"><label>Init Dice:</label><input type="number" name="system.attributeMods.initiativeDice" value="{{system.attributeMods.initiativeDice}}" /></div>
    </div>
    <div class="form-group">
      <label>No Reaction bonus:</label>
      <input type="checkbox" name="system.noReactionBonus" {{checked system.noReactionBonus}} />
      <span class="hint">(Adrenal Pump: its +Quickness doesn't raise Reaction)</span>
    </div>
  </fieldset>
  {{/ifEquals}}

  {{#ifEquals type "cyberware"}}
  <div class="form-group">
    <label>Location:</label>
    <select name="system.location">
      {{#each config.cyberwareLocations as |label key|}}
      <option value="{{key}}" {{selected ../system.location key}}>{{localize label}}</option>
      {{/each}}
    </select>
  </div>
  <div class="form-group">
    <label>Grade:</label>
    <select name="system.grade">
      {{#each config.cyberwareGrades as |grade key|}}
      <option value="{{key}}" {{selected ../system.grade key}}>{{localize grade.label}}</option>
      {{/each}}
    </select>
  </div>

  {{!-- Rating: dropdown from table tiers (if tiered) or plain number input --}}
  <div class="form-group">
    <label>Rating:</label>
    {{#if hasRatingTable}}
    <select name="system.rating">
      {{#each system.ratingStats}}
      <option value="{{this.rating}}" {{selected ../system.rating this.rating}}>{{this.rating}}</option>
      {{/each}}
    </select>
    {{else}}
    <input type="number" name="system.rating" value="{{system.rating}}" min="0" />
    {{/if}}
  </div>

  {{!-- Flat fields: only shown when there is NO rating table --}}
  {{#unless hasRatingTable}}
  <div class="form-group">
    <label>Essence Cost:</label>
    <input type="number" name="system.essenceCost" value="{{system.essenceCost}}" min="0" step="0.1" />
    {{#if gradeReducesEssence}}
    <span class="hint">(Actual: {{system.actualEssenceCost}})</span>
    {{/if}}
  </div>
  <div class="form-group">
    <label>Cost (¥):</label>
    <input type="number" name="system.cost" value="{{system.cost}}" />
  </div>
  <div class="form-group">
    <label>Availability:</label>
    <input type="text" name="system.availability" value="{{system.availability}}" />
  </div>
  <div class="form-group">
    <label>Street Index:</label>
    <input type="text" name="system.streetIndex" value="{{system.streetIndex}}" />
  </div>
  {{/unless}}

  <div class="form-group">
    <label>Installed:</label>
    <input type="checkbox" name="system.installed" {{checked system.installed}} />
  </div>
  <div class="form-group">
    <label>Combat TN Modifier:</label>
    <input type="number" name="system.combatTnMod" value="{{system.combatTnMod}}" />
    <span class="hint">(e.g. −1 for Smartlink; applies to compatible weapons only)</span>
  </div>
  <div class="form-group">
    <label>Vehicle Control Rig:</label>
    <input type="checkbox" name="system.isVcr" {{checked system.isVcr}} />
    <span class="hint">(when installed, this item's Rating sets the character's VCR level)</span>
  </div>
  <div class="form-group">
    <label>Tactical Computer:</label>
    <input type="checkbox" name="system.isTacticalComputer" {{checked system.isTacticalComputer}} />
    <span class="hint">(adds its Rating to Initiative, never past the natural Reaction max; no help rigging/decking)</span>
  </div>
  <div class="form-group">
    <label title="Power added to the wearer's unarmed blows while installed. Bone lacing (Shadowtech p.42): plastic +1, aluminum +2, titanium +3 — the innate Unarmed Strike becomes (Str+N)M. The highest installed value wins; laces don't stack. 0 = no effect.">Unarmed Power Bonus:</label>
    <input type="number" name="system.unarmedPowerBonus" value="{{system.unarmedPowerBonus}}" min="0" />
  </div>
  <div class="form-group">
    <label title="Matrixware — a cyberdeck built into the skull (Shadowtech p.54)">Cranial Cyberdeck (C2):</label>
    <input type="checkbox" name="system.cranialDeck" {{checked system.cranialDeck}} />
    <span class="hint">(drives the Matrix tab like a gear deck; Essence is derived from the components below)</span>
  </div>

  {{#if system.cranialDeck}}
  <hr/>
  <p class="hint">Cranial cyberdeck / "C2" (Matrixware, Shadowtech p.54–59). Activate it on the Gear tab (⚡) to drive the Matrix tab — only one deck (gear or cranial) is active at a time. Persona programs (Bod/Evasion/Masking/Sensor) are separate program items capped by MPCP. <strong>Essence is derived: {{formatEssence system.actualEssenceCost}}</strong> — MPCP (Rating/10 + 0.1) + Persona 0.30 + Hardening 0.3 + Transfer 0.1 + Response 0.2. Caps: MPCP ≤ 1.5 × Intelligence (over = <strong>+4 TN to every action</strong>), Persona ≤ 75% MPCP, Hardening ≤ ½ MPCP, Response ≤ MPCP/4.</p>
  <div class="form-group"><label>MPCP:</label>
    <input type="number" name="system.deck.mpcp" value="{{system.deck.mpcp}}" min="0" /></div>
  <div class="form-group"><label>Hardening:</label>
    <input type="number" name="system.deck.hardening" value="{{system.deck.hardening}}" min="0" /></div>
