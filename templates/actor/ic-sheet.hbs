<section class="sr2e-ic-sheet">
  <div class="ic-header flexrow">
    <img src="{{actor.img}}" alt="{{actor.name}}" data-edit="img" class="profile-img" />
    <div class="header-info flexcol">
      <input type="text" name="name" value="{{actor.name}}" placeholder="IC Name" />
      <div class="ic-details flexrow">
        <div class="form-group">
          <label>Type:</label>
          <select name="system.icType">
            {{#each config.icTypes as |label key|}}
            <option value="{{key}}" {{selected ../system.icType key}}>{{localize label}}</option>
            {{/each}}
          </select>
        </div>
        <div class="form-group">
          <label>Rating:</label>
          <input type="number" name="system.rating" value="{{system.rating}}" min="1" />
        </div>
      </div>
      <div class="ic-details flexrow">
        <div class="form-group">
          <label>Node Code:</label>
          <select name="system.securityCode">
            {{#each config.securityCodes as |sec key|}}
            <option value="{{key}}" {{selected ../system.securityCode key}}>{{localize sec.label}}</option>
            {{/each}}
          </select>
        </div>
        <div class="form-group">
          <label>Alert:</label>
          <select name="system.alert">
            {{#each config.alertStates as |label key|}}
            <option value="{{key}}" {{selected ../system.alert key}}>{{localize label}}</option>
            {{/each}}
          </select>
        </div>
      </div>
    </div>
  </div>

  {{#ifEquals system.alert "none"}}{{else}}
  <p style="margin:2px 0;color:#d9a441;font-size:11px;">
    <i class="fas fa-triangle-exclamation"></i> Alert active — IC ratings boosted +50%
    (effective Rating <strong>{{system.effectiveRating}}</strong>, SR2E p.168).
  </p>
  {{/ifEquals}}

  <fieldset>
    <legend>Persona Attributes</legend>
    <div class="attr-grid">
      <div class="attr-item"><label>Bod</label><input type="number" name="system.bod" value="{{system.bod}}" min="0" /></div>
      <div class="attr-item"><label>Evasion</label><input type="number" name="system.evasion" value="{{system.evasion}}" min="0" /></div>
      <div class="attr-item"><label>Masking</label><input type="number" name="system.masking" value="{{system.masking}}" min="0" /></div>
      <div class="attr-item"><label>Sensor</label><input type="number" name="system.sensor" value="{{system.sensor}}" min="0" /></div>
      <div class="attr-item"><label>Attack</label><input type="number" name="system.attack" value="{{system.attack}}" min="0" /></div>
    </div>
  </fieldset>

  <fieldset>
    <legend>Condition</legend>
    <input type="number" name="system.conditionMonitor.value" value="{{system.conditionMonitor.value}}" min="0" max="{{system.conditionMonitor.max}}" />
    <span>/ {{system.conditionMonitor.max}}</span>
  </fieldset>

  <div class="ic-actions" style="margin:6px 0;">
    <button type="button" data-action="matrixAttack" title="Attack a persona in the Matrix (IC Rating dice vs the target's Bod, SR2E p.178).">
      <i class="fas fa-bolt"></i> Matrix Attack
    </button>
  </div>

  <fieldset>
    <legend>Initiative</legend>
    <span>{{system.initiative.value}} + {{system.initiative.dice}}d6</span>
  </fieldset>

  <fieldset>
    <legend>Notes</legend>
    <div class="editor-content">{{{system.notes}}}</div>
    {{#if editable}}
    <textarea name="system.notes" style="display:none;">{{system.notes}}</textarea>
    {{/if}}
  </fieldset>
</section>
