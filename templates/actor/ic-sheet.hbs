<section class="sr2e-matrix-sheet sr2e-ic-sheet">
  <header class="sr2e-matrix-header">
    <img src="{{actor.img}}" alt="{{actor.name}}" data-edit="img" />
    <div class="title-block">
      <input type="text" name="name" value="{{actor.name}}" placeholder="IC Name" class="actor-name" />
      <span class="subtitle">{{localize (lookup config.icTypes system.icType)}}</span>
    </div>
    <div class="rating-badge">
      <span class="code">RATING</span>
      <span class="num">{{system.effectiveRating}}</span>
    </div>
  </header>

  <div class="field-grid">
    <label class="field">
      <span>Type</span>
      <select name="system.icType">
        {{#each config.icTypes as |label key|}}
        <option value="{{key}}" {{selected ../system.icType key}}>{{localize label}}</option>
        {{/each}}
      </select>
    </label>
    <label class="field">
      <span>Rating</span>
      <input type="number" name="system.rating" value="{{system.rating}}" min="1" />
    </label>
  </div>

  <fieldset class="node-link">
    <legend>Node</legend>
    <label class="field">
      <span>Defends Host</span>
      <select name="system.hostUuid" title="Link a Host node; its Security Code and alert sync to this IC automatically.">
        <option value="" {{#unless system.hostUuid}}selected{{/unless}}>— none (set manually) —</option>
        {{#each hosts as |host|}}
        <option value="{{host.uuid}}" {{selected ../system.hostUuid host.uuid}}>{{host.name}}</option>
        {{/each}}
      </select>
    </label>
    <div class="field-grid">
      <label class="field">
        <span>Node Code</span>
        <select name="system.securityCode" {{#if system.hostUuid}}disabled{{/if}}>
          {{#each config.securityCodes as |sec key|}}
          <option value="{{key}}" {{selected ../system.securityCode key}}>{{localize sec.label}}</option>
          {{/each}}
        </select>
      </label>
      <label class="field">
        <span>Alert</span>
        <select name="system.alert" {{#if system.hostUuid}}disabled{{/if}}>
          {{#each config.alertStates as |label key|}}
          <option value="{{key}}" {{selected ../system.alert key}}>{{localize label}}</option>
          {{/each}}
        </select>
      </label>
    </div>
    {{#if linkedHost}}
    <p class="rule-note"><i class="fas fa-link"></i> Code &amp; alert synced from <strong>{{linkedHost.name}}</strong>.</p>
    {{/if}}
    {{#ifEquals system.alert "none"}}{{else}}
    <p class="alert-note passive"><i class="fas fa-triangle-exclamation"></i> Alert — ratings boosted +50% (effective Rating {{system.effectiveRating}}, p.168).</p>
    {{/ifEquals}}
  </fieldset>

  <fieldset>
    <legend>Persona Attributes</legend>
    <div class="attr-grid">
      <label class="attr"><span>Bod</span><input type="number" name="system.bod" value="{{system.bod}}" min="0" /></label>
      <label class="attr"><span>Evasion</span><input type="number" name="system.evasion" value="{{system.evasion}}" min="0" /></label>
      <label class="attr"><span>Masking</span><input type="number" name="system.masking" value="{{system.masking}}" min="0" /></label>
      <label class="attr"><span>Sensor</span><input type="number" name="system.sensor" value="{{system.sensor}}" min="0" /></label>
      <label class="attr"><span>Attack</span><input type="number" name="system.attack" value="{{system.attack}}" min="0" /></label>
    </div>
  </fieldset>

  <div class="stat-row">
    <div class="stat">
      <span class="stat-label">Condition</span>
      <span class="stat-value">
        <input type="number" name="system.conditionMonitor.value" value="{{system.conditionMonitor.value}}" min="0" max="{{system.conditionMonitor.max}}" />
        <span>/ {{system.conditionMonitor.max}}</span>
      </span>
    </div>
    <div class="stat">
      <span class="stat-label">Initiative</span>
      <span class="stat-value">{{system.initiative.value}} + {{system.initiative.dice}}d6</span>
    </div>
  </div>

  <div class="ic-action-row">
    <button type="button" class="matrix-attack-btn" data-action="matrixAttack" title="Attack a persona in the Matrix (IC Rating dice vs the target's Bod, SR2E p.178).">
      <i class="fas fa-bolt"></i> Matrix Attack
    </button>
    <button type="button" class="matrix-attack-btn" data-action="matrixPerception" title="Scan for an intruder: IC Rating vs the persona's Masking; any success raises the alert (SR2E p.169).">
      <i class="fas fa-magnifying-glass"></i> Detect Intruder
    </button>
  </div>

  <fieldset>
    <legend>Notes</legend>
    <div class="editor-content">{{{system.notes}}}</div>
    {{#if editable}}
    <textarea name="system.notes" style="display:none;">{{system.notes}}</textarea>
    {{/if}}
  </fieldset>
</section>
