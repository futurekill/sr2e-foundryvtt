<section class="sr2e-host-sheet">
  <div class="host-header flexrow">
    <img src="{{actor.img}}" alt="{{actor.name}}" data-edit="img" class="profile-img" />
    <div class="header-info flexcol">
      <input type="text" name="name" value="{{actor.name}}" placeholder="Node Name" />
      <div class="host-details flexrow">
        <div class="form-group">
          <label>Security Code:</label>
          <select name="system.securityCode">
            {{#each config.securityCodes as |sec key|}}
            <option value="{{key}}" {{selected ../system.securityCode key}}>{{localize sec.label}}</option>
            {{/each}}
          </select>
        </div>
        <div class="form-group">
          <label>System Rating <span style="font-size:10px;color:#aaa1c0;">(TN)</span>:</label>
          <input type="number" name="system.systemRating" value="{{system.systemRating}}" min="1" />
        </div>
      </div>
    </div>
  </div>

  <fieldset>
    <legend>Security Rating</legend>
    <p style="margin:2px 0;">
      <strong>{{localize (lookup (lookup config.securityCodes system.securityCode) "label")}}-{{system.systemRating}}</strong>
      — a decker must beat <strong>{{successesNeeded}}</strong>
      successes on a Computer Test (TN {{system.systemRating}})
      to make this node execute an operation (SR2E p.165).
    </p>
  </fieldset>

  <fieldset>
    <legend>Intrusion</legend>
    <div class="flexrow" style="align-items:center;gap:12px;">
      <div class="form-group">
        <label>Alert:</label>
        <select name="system.alert">
          {{#each config.alertStates as |label key|}}
          <option value="{{key}}" {{selected ../system.alert key}}>{{localize label}}</option>
          {{/each}}
        </select>
      </div>
      <div class="form-group">
        <label>Attempts:</label>
        <input type="number" name="system.attempts" value="{{system.attempts}}" min="0" style="width:52px;text-align:center;" />
      </div>
      <button type="button" data-action="resetHostTally" title="Reset the intrusion tally and clear the alert.">
        <i class="fas fa-rotate-left"></i> Reset
      </button>
    </div>
    {{#ifEquals system.alert "passive"}}
    <p style="margin:4px 0;color:#d9a441;font-size:11px;">
      <i class="fas fa-triangle-exclamation"></i> Passive alert — apply +50% to all IC ratings (SR2E p.168).
    </p>
    {{/ifEquals}}
    {{#ifEquals system.alert "active"}}
    <p style="margin:4px 0;color:#c44;font-size:11px;">
      <i class="fas fa-bell"></i> Active alert — operators respond; the system may shut down (2D6 turns).
    </p>
    {{/ifEquals}}
  </fieldset>

  <fieldset>
    <legend>Notes</legend>
    <div class="editor-content">{{{system.notes}}}</div>
    {{#if editable}}
    <textarea name="system.notes" style="display:none;">{{system.notes}}</textarea>
    {{/if}}
  </fieldset>
</section>
