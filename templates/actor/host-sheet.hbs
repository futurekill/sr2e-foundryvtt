<section class="sr2e-matrix-sheet sr2e-host-sheet">
  <header class="sr2e-matrix-header">
    <img src="{{actor.img}}" alt="{{actor.name}}" data-action="editImage" title="Click to change portrait" style="cursor:pointer;" />
    <div class="title-block">
      <input type="text" name="name" value="{{actor.name}}" placeholder="Node Name" class="actor-name" />
      <span class="subtitle">Matrix Host / Node</span>
    </div>
    <div class="rating-badge">
      <span class="code code-{{system.securityCode}}">{{localize (lookup (lookup config.securityCodes system.securityCode) "label")}}</span>
      <span class="num">{{system.systemRating}}</span>
    </div>
  </header>

  <div class="field-grid">
    <label class="field">
      <span>Security Code</span>
      <select name="system.securityCode">
        {{#each config.securityCodes as |sec key|}}
        <option value="{{key}}" {{selected ../system.securityCode key}}>{{localize sec.label}}</option>
        {{/each}}
      </select>
    </label>
    <label class="field">
      <span>System Rating <em>(TN)</em></span>
      <input type="number" name="system.systemRating" value="{{system.systemRating}}" min="1" />
    </label>
  </div>

  <p class="rule-note">
    A decker must beat <strong>{{successesNeeded}}</strong>
    success{{#ifEquals successesNeeded 1}}{{else}}es{{/ifEquals}} on a Computer Test
    (TN {{system.systemRating}}) to make this node execute an operation (SR2E p.165).
  </p>

  <fieldset class="intrusion">
    <legend>Intrusion</legend>
    <div class="field-grid">
      <label class="field">
        <span>Alert</span>
        <select name="system.alert">
          {{#each config.alertStates as |label key|}}
          <option value="{{key}}" {{selected ../system.alert key}}>{{localize label}}</option>
          {{/each}}
        </select>
      </label>
      <label class="field">
        <span>Attempts</span>
        <input type="number" name="system.attempts" value="{{system.attempts}}" min="0" />
      </label>
    </div>
    <button type="button" class="reset-btn" data-action="resetHostTally" title="Reset the intrusion tally and clear the alert.">
      <i class="fas fa-rotate-left"></i> Reset Tally
    </button>
    {{#ifEquals system.alert "passive"}}
    <p class="alert-note passive"><i class="fas fa-triangle-exclamation"></i> Passive alert — all IC ratings +50% (SR2E p.168).</p>
    {{/ifEquals}}
    {{#ifEquals system.alert "active"}}
    <p class="alert-note active"><i class="fas fa-bell"></i> Active alert — operators respond; the system may shut down.</p>
    {{/ifEquals}}
  </fieldset>

  <fieldset>
    <legend>Notes</legend>
    <div class="editor-content">{{{system.notes}}}</div>
    {{#if editable}}
    <textarea name="system.notes" style="display:none;">{{system.notes}}</textarea>
    {{/if}}
  </fieldset>
</section>
