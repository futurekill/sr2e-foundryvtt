<section class="sr2e-vehicle-sheet tab-content {{#if tab.active}}active{{/if}}" data-tab="overview" data-group="primary">
  <div class="vehicle-header flexrow">
    <img src="{{actor.img}}" alt="{{actor.name}}" data-edit="img" class="profile-img" />
    <div class="header-info flexcol">
      <input type="text" name="name" value="{{actor.name}}" placeholder="Vehicle Name" />
      <div class="form-group">
        <label>Type:</label>
        <select name="system.vehicleType">
          {{#each config.vehicleTypes as |label key|}}
          <option value="{{key}}" {{selected ../system.vehicleType key}}>{{localize label}}</option>
          {{/each}}
        </select>
      </div>
      <div class="form-group">
        <label title="Driving skill used for vehicle tests; blank = type default (car / pilot)">Skill:</label>
        <input type="text" name="system.skill" value="{{system.skill}}"
               placeholder="{{system.drivingSkill}}" />
      </div>
    </div>
  </div>

  <fieldset class="vehicle-stats">
    <legend>Vehicle Statistics</legend>
    <div class="stat-grid">
      <div class="stat-item">
        <label>Handling</label>
        <input type="number" name="system.handling" value="{{system.handling}}" />
      </div>
      <div class="stat-item">
        <label>Speed</label>
        <input type="number" name="system.speed" value="{{system.speed}}" />
      </div>
      <div class="stat-item">
        <label>Accel</label>
        <input type="number" name="system.acceleration" value="{{system.acceleration}}" />
      </div>
      <div class="stat-item">
        <label>Body</label>
        <input type="number" name="system.body" value="{{system.body}}" />
      </div>
      <div class="stat-item">
        <label>Armor</label>
        <input type="number" name="system.armor" value="{{system.armor}}" />
      </div>
      <div class="stat-item">
        <label>Signature</label>
        <input type="number" name="system.signature" value="{{system.signature}}" />
      </div>
      <div class="stat-item">
        <label>Pilot</label>
        <input type="number" name="system.pilot" value="{{system.pilot}}" />
      </div>
      <div class="stat-item">
        <label>Sensor</label>
        <input type="number" name="system.sensor" value="{{system.sensor}}" />
      </div>
      <div class="stat-item">
        <label>Autonav</label>
        <input type="number" name="system.autonav" value="{{system.autonav}}" />
      </div>
    </div>
  </fieldset>

  <div class="vehicle-body flexrow">
    <fieldset>
      <legend>Condition</legend>
      <input type="number" name="system.conditionMonitor.value" value="{{system.conditionMonitor.value}}" min="0" max="{{system.conditionMonitor.max}}" />
      <span>/ {{system.conditionMonitor.max}}</span>
    </fieldset>

    <fieldset>
      <legend>Details</legend>
      <div class="form-group">
        <label>Seating:</label>
        <input type="text" name="system.seating" value="{{system.seating}}" />
      </div>
      <div class="form-group">
        <label>Cost:</label>
        <input type="number" name="system.cost" value="{{system.cost}}" />
      </div>
    </fieldset>
  </div>

  <fieldset class="vehicle-mods">
    <legend class="flexrow">
      <span>Modifications</span>
      {{#if editable}}
      <button type="button" data-action="addItem" data-type="vehicle_mod" class="btn-add" title="Add a modification">
        <i class="fas fa-plus"></i>
      </button>
      {{/if}}
    </legend>
    <div class="item-list">
      {{#each mods as |mod|}}
      <div class="item-row flexrow" data-item-id="{{mod.id}}" draggable="true">
        <span class="item-name"><i class="fas fa-wrench"></i> {{mod.name}}</span>
        {{#if mod.rated}}{{#if editable}}
        <label class="item-rating" title="Rating">R <input type="number" data-field="system.rating" value="{{mod.rating}}" min="0" /></label>
        {{else}}<span class="item-meta">R{{mod.rating}}</span>{{/if}}{{/if}}
        <div class="item-controls">
          <a data-action="editItem" title="Edit"><i class="fas fa-edit"></i></a>
          <a data-action="deleteItem" title="Delete"><i class="fas fa-trash"></i></a>
        </div>
      </div>
      {{else}}
      <p class="empty-hint">No modifications. Drag a vehicle mod from a compendium onto this sheet, or use +.</p>
      {{/each}}
    </div>
  </fieldset>

  <fieldset class="vehicle-weapons">
    <legend class="flexrow">
      <span>Weapons</span>
      {{#if editable}}
      <button type="button" data-action="addItem" data-type="weapon" class="btn-add" title="Add a weapon">
        <i class="fas fa-plus"></i>
      </button>
      {{/if}}
    </legend>
    <div class="item-list">
      {{#each weapons as |wpn|}}
      <div class="item-row flexrow" data-item-id="{{wpn.id}}" draggable="true">
        <span class="item-name"><i class="fas fa-crosshairs"></i> {{wpn.name}}</span>
        {{#if wpn.system.damageCode}}<span class="item-meta">{{wpn.system.damageCode}}</span>{{/if}}
        <div class="item-controls">
          <a data-action="editItem" title="Edit"><i class="fas fa-edit"></i></a>
          <a data-action="deleteItem" title="Delete"><i class="fas fa-trash"></i></a>
        </div>
      </div>
      {{else}}
      <p class="empty-hint">No weapons mounted.</p>
      {{/each}}
    </div>
  </fieldset>

  <fieldset>
    <legend>Notes</legend>
    <div class="editor-content">{{{system.notes}}}</div>
    {{#if editable}}
    <textarea name="system.notes" style="display:none;">{{system.notes}}</textarea>
    {{/if}}
  </fieldset>
</section>
