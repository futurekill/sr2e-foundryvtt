<section class="tab-content {{#if tab.active}}active{{/if}}" data-tab="skills" data-group="primary">
  <div class="skills-section">

    {{!-- Active Skills --}}
    <div class="skill-category">
      <div class="skill-header flexrow">
        <h3>{{localize "SR2E.Skills.Active"}}</h3>
        <button type="button" data-action="addItem" data-type="skill" class="btn-add">
          <i class="fas fa-plus"></i>
        </button>
      </div>
      <div class="skill-list">
        {{#each skills as |skill|}}
        {{#ifEquals skill.system.category "active"}}
        <div class="skill-row flexrow" data-item-id="{{skill.id}}" {{#if skill.system._synthetic}}data-soft-id="{{skill.softId}}"{{/if}}>
          <span class="skill-name" data-action="rollSkill">
            <i class="fas fa-dice"></i>
            {{skill.name}}{{#if skill.system.concentration.name}}<span class="skill-conc-inline" data-variant="concentration" title="Concentration — roll {{skill.system.concentration.rating}} dice (SR2E p.70)"> ({{skill.system.concentration.name}} {{skill.system.concentration.rating}})</span>{{/if}}{{#if skill.system.specialization.name}}<span class="skill-spec-inline" data-variant="specialization" title="Specialization — roll {{skill.system.specialization.rating}} dice (SR2E p.70)"> [{{skill.system.specialization.name}} {{skill.system.specialization.rating}}]</span>{{/if}}{{#if skill.system._chipped}}<span class="chip-badge" title="Chipped from slotted {{skill.system._chipSource}}{{#if skill.system._nativeRating}} — natural rating {{skill.system._nativeRating}} suppressed{{/if}}"><i class="fas fa-bolt"></i></span>{{/if}}
          </span>
          <span class="skill-attr">({{skill.system.linkedAttribute}})</span>
          {{#if skill.system._chipped}}
          <span class="skill-rating chipped" title="From a slotted skillsoft">{{skill.system.rating}}</span>
          {{else}}
          <input type="number" value="{{skill.system.rating}}" data-field="system.rating"
                 class="skill-rating" min="0" max="12" />
          {{/if}}
          <div class="item-controls">
            {{#unless skill.system._synthetic}}
            <a data-action="editItem" title="Edit"><i class="fas fa-edit"></i></a>
            <a data-action="deleteItem" title="Delete"><i class="fas fa-trash"></i></a>
            {{/unless}}
          </div>
        </div>
        {{/ifEquals}}
        {{/each}}
      </div>
    </div>

    {{!-- Build/Repair Skills --}}
    <div class="skill-category">
      <div class="skill-header flexrow">
        <h3>{{localize "SR2E.Skills.BuildRepair"}}</h3>
        <button type="button" data-action="addItem" data-type="skill" class="btn-add" data-category="build_repair">
          <i class="fas fa-plus"></i>
        </button>
      </div>
      <div class="skill-list">
        {{#each skills as |skill|}}
        {{#ifEquals skill.system.category "build_repair"}}
        <div class="skill-row flexrow" data-item-id="{{skill.id}}">
          <span class="skill-name" data-action="rollSkill">
            <i class="fas fa-dice"></i>
            {{skill.name}}{{#if skill.system.concentration.name}}<span class="skill-conc-inline" data-variant="concentration" title="Concentration — roll {{skill.system.concentration.rating}} dice (SR2E p.70)"> ({{skill.system.concentration.name}} {{skill.system.concentration.rating}})</span>{{/if}}{{#if skill.system.specialization.name}}<span class="skill-spec-inline" data-variant="specialization" title="Specialization — roll {{skill.system.specialization.rating}} dice (SR2E p.70)"> [{{skill.system.specialization.name}} {{skill.system.specialization.rating}}]</span>{{/if}}
          </span>
          <span class="skill-attr">({{skill.system.linkedAttribute}})</span>
          <input type="number" value="{{skill.system.rating}}" data-field="system.rating"
                 class="skill-rating" min="0" max="12" />
          <div class="item-controls">
            <a data-action="editItem" title="Edit"><i class="fas fa-edit"></i></a>
            <a data-action="deleteItem" title="Delete"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/ifEquals}}
        {{/each}}
      </div>
    </div>

    {{!-- Knowledge Skills --}}
    <div class="skill-category">
      <div class="skill-header flexrow">
        <h3>{{localize "SR2E.Skills.Knowledge"}}</h3>
        <button type="button" data-action="addItem" data-type="skill" class="btn-add">
