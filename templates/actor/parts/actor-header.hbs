<section class="sr2e-sheet-header flexrow">
  <div class="profile-img">
    <img src="{{actor.img}}" alt="{{actor.name}}" data-action="editImage" title="Click to change portrait" style="cursor:pointer;" />
  </div>
  <div class="header-info flexcol">

    {{!-- Row 1: Name + shadowtalk banter (fills the unused top-right space) --}}
    <div class="header-name-row flexrow">
      <div class="char-name-stack flexcol">
        <input type="text" name="name" value="{{actor.name}}" placeholder="Street Name" class="char-name-input"
               title="The handle this character runs under. Foundry uses it for the token, the sidebar and chat cards." />
        <input type="text" name="system.realName" value="{{system.realName}}" placeholder="Government name (optional)"
               class="char-realname-input" title="The name on the SIN, if the character admits to one. Never shown on tokens or chat." />
      </div>
      {{#if shadowtalk}}
      <div class="sr2e-shadowtalk header-shadowtalk" title="Shadowland chatter — set frequency in system settings">
        <span>&gt;&gt;&gt;&gt;&gt;[{{shadowtalk.text}}]&lt;&lt;&lt;&lt;&lt;</span>
        <span class="sr2e-shadowtalk-by">— {{shadowtalk.by}}</span>
      </div>
      {{/if}}
    </div>

    {{!-- Row 2: Race (drag-drop from Metatypes compendium) + dice pool indicators --}}
    <div class="header-race-row flexrow">
      <label class="race-label">{{localize "SR2E.Race.Label"}}:</label>
      {{!-- Race drop zone: shows current race name; accepts a 'race' item dropped from compendium --}}
      <div class="race-drop-zone" title="Drag a metatype from the SR2E Metatypes compendium to set this character's race." data-drop="race">
        <span class="race-name">{{localizeRace system.race config.races}}</span>
        <i class="fas fa-arrows-alt race-drop-icon"></i>
      </div>

      {{!-- Pool dice remaining — only show pools with a computed max > 0 --}}
      <div class="header-pools">
        {{#if system.dicePools.combat.max}}
        <span class="pool-pip" title="Combat Pool — spent dice reset each combat round">
          <span class="pool-pip-label">CP</span>
          <span class="pool-pip-value">{{system.dicePools.combat.value}}/{{system.dicePools.combat.max}}</span>
        </span>
        {{/if}}
        {{#if system.dicePools.magic.max}}
        <span class="pool-pip" title="Magic Pool — spent dice reset each combat round">
          <span class="pool-pip-label">MP</span>
          <span class="pool-pip-value">{{system.dicePools.magic.value}}/{{system.dicePools.magic.max}}</span>
        </span>
        {{/if}}
        {{#if system.dicePools.hacking.max}}
        <span class="pool-pip" title="Hacking Pool">
          <span class="pool-pip-label">HP</span>
          <span class="pool-pip-value">{{system.dicePools.hacking.value}}/{{system.dicePools.hacking.max}}</span>
        </span>
        {{/if}}
        {{#if system.dicePools.control.max}}
        <span class="pool-pip" title="Control Pool">
          <span class="pool-pip-label">CtP</span>
          <span class="pool-pip-value">{{system.dicePools.control.value}}/{{system.dicePools.control.max}}</span>
        </span>
        {{/if}}
      </div>
    </div>

    {{!-- Row 2.5: Condition status --}}
    <div class="header-condition-row flexrow">
      <span class="condition-badge {{woundLevelClass woundLevel}}">
        {{#ifEquals woundLevel "Undamaged"}}Healthy{{else}}{{woundLevel}}{{/ifEquals}}
      </span>
      <span class="condition-damage">
        <span class="dmg-type">P</span>{{system.conditionMonitor.physical.value}}/{{system.conditionMonitor.physical.max}}
        &nbsp;
        <span class="dmg-type">S</span>{{system.conditionMonitor.stun.value}}/{{system.conditionMonitor.stun.max}}
      </span>
      {{#if system.sustainPenalty}}
      <span class="condition-sustain" title="Sustained-spell penalty: +2 TN per sustained spell (spell locks exempt)">
        <i class="fas fa-hand-sparkles"></i> +{{system.sustainPenalty}} TN
      </span>
      {{/if}}
    </div>

    {{!-- Row 3: Stats grid — Essence | Nuyen | Good Karma | Karma Pool --}}
    <div class="header-stats-row flexrow">
      <div class="header-stat">
        <span class="hstat-label">{{localize "SR2E.Essence"}}</span>
        <span class="hstat-value essence-value">{{formatEssence system.essence.value}}</span>
      </div>
      <div class="header-stat">
        <span class="hstat-label">{{localize "SR2E.Nuyen"}} (¥)</span>
        <input type="number" name="system.nuyen" value="{{system.nuyen}}" class="hstat-input" />
      </div>
      <div class="header-stat" title="Good Karma available to spend on advancement">
        <span class="hstat-label">Good Karma</span>
        <input type="number" name="system.karma.current" value="{{system.karma.current}}" min="0" class="hstat-input" />
      </div>
      <div class="header-stat" title="Karma Pool dice — usable on any roll, refresh each session">
        <span class="hstat-label">Karma Pool</span>
        <input type="number" name="system.karma.pool" value="{{system.karma.pool}}" min="0" class="hstat-input" />
      </div>
      <div class="header-stat" title="Shared Team Karma Pool — contribute/draw on the Bio tab (SR2E p.246)">
        <span class="hstat-label">Team Karma</span>
        <span class="hstat-value team-karma-value">{{teamKarma}}</span>
      </div>
    </div>

  </div>
</section>
