<section class="tab-content {{#if tab.active}}active{{/if}}" data-tab="gear" data-group="primary">
  <div class="gear-section">

    {{!-- Cyberware --}}
    <div class="gear-category">
      <div class="category-header flexrow">
        <h3>Cyberware</h3>
        <span class="essence-display">Essence: {{formatEssence system.essence.value}} / {{formatEssence system.essence.max}}</span>
        <button type="button" data-action="addItem" data-type="cyberware" class="btn-add">
          <i class="fas fa-plus"></i>
        </button>
      </div>
      <div class="item-list">
        {{#each cyberware as |cyber|}}
        <div class="item-row cyber-row flexrow" data-item-id="{{cyber.id}}">
          <span class="item-name">
            <i class="fas fa-microchip"></i>
            {{cyber.name}}
          </span>
          <span class="cyber-location">{{cyber.system.location}}</span>
          <span class="cyber-grade">{{cyber.system.grade}}</span>
          <span class="cyber-essence">Ess: {{cyber.system.actualEssenceCost}}</span>
          <span class="cyber-installed">
            {{#if cyber.system.installed}}<i class="fas fa-check-circle"></i>{{else}}<i class="fas fa-times-circle"></i>{{/if}}
          </span>
          <div class="item-controls">
            <a data-action="toggleEquip" title="Install/Remove"><i class="fas fa-wrench"></i></a>
            <a data-action="editItem"><i class="fas fa-edit"></i></a>
            <a data-action="deleteItem"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- Skillsofts --}}
    <div class="gear-category">
      <div class="category-header flexrow">
        <h3>Skillsofts</h3>
        <span class="essence-display" title="ActiveSofts share the Skillwire Rating as a total-rating budget; each chipjack runs one Know/LinguaSoft; headware memory stores the chips (Mp).">
          ActiveSoft {{skillsoftCapacity.activeUsed}}/{{skillsoftCapacity.skillwiresRating}} · Chips {{skillsoftCapacity.chipUsed}}/{{skillsoftCapacity.chipjacks}} · Mem {{skillsoftCapacity.memUsed}}{{#ifGt skillsoftCapacity.memCapacity 0}}/{{skillsoftCapacity.memCapacity}}{{/ifGt}} Mp
        </span>
        <button type="button" data-action="addItem" data-type="gear" data-category="skillsoft" class="btn-add">
          <i class="fas fa-plus"></i>
        </button>
      </div>
      <div class="item-list">
        {{#each skillsofts as |soft|}}
        <div class="item-row flexrow {{#if soft.system.slotted}}soft-slotted{{/if}} {{#if soft.system._overBudget}}soft-overbudget{{/if}}" data-item-id="{{soft.id}}">
          <span class="item-name">{{soft.name}}</span>
          <span class="soft-grant">{{#if soft.system.grantedSkill}}{{soft.system.grantedSkill}} {{soft.system.rating}}{{else}}<em>(set granted skill)</em>{{/if}}</span>
          <span class="soft-type" title="{{soft.system.cost}}¥">{{soft.system.mp}} Mp</span>
          {{#if soft.system._overBudget}}<span class="soft-warn" title="Slotted but not running — over the Skillwire/chipjack capacity"><i class="fas fa-triangle-exclamation"></i></span>{{/if}}
          <div class="item-controls">
            <a data-action="toggleSlot" title="{{#if soft.system.slotted}}Un-slot{{else}}Slot{{/if}}">
              <i class="fas {{#if soft.system.slotted}}fa-bolt{{else}}fa-power-off{{/if}}"></i>
            </a>
            <a data-action="editItem"><i class="fas fa-edit"></i></a>
            <a data-action="deleteItem"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- General Gear --}}
    <div class="gear-category">
      <div class="category-header flexrow">
        <h3>Equipment</h3>
        <button type="button" data-action="addItem" data-type="gear" class="btn-add">
          <i class="fas fa-plus"></i>
        </button>
      </div>
      <div class="item-list">
        {{#each gear as |g|}}
        <div class="item-row flexrow" data-item-id="{{g.id}}">
          <span class="item-name">{{g.name}}</span>
          {{#ifGt g.system.rating 0}}
          <span>Rating: {{g.system.rating}}</span>
          {{/ifGt}}
          {{#if g.system.weaponAccessory}}
          <span class="weapon-mount" title="Attach this accessory to one weapon; its modifiers then apply to that weapon's attacks.">
            <i class="fas fa-link"></i>
            <select data-field="system.linkedWeaponId">
              <option value="" {{#unless g.system.linkedWeaponId}}selected{{/unless}}>— unattached —</option>
              {{#each @root.weapons as |w|}}
              <option value="{{w.id}}" {{selected g.system.linkedWeaponId w.id}}>{{w.name}}</option>
              {{/each}}
            </select>
          </span>
          {{else}}
          <span>Qty: {{g.system.quantity}}</span>
          {{/if}}
          <span>{{g.system.cost}}¥</span>
          <div class="item-controls">
            <a data-action="toggleEquip" title="Equip/Unequip">
              <i class="fas {{#if g.system.equipped}}fa-check-circle{{else}}fa-circle{{/if}}"></i>
            </a>
            <a data-action="editItem"><i class="fas fa-edit"></i></a>
            <a data-action="deleteItem"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- Lifestyles --}}
    <div class="gear-category">
      <div class="category-header flexrow">
        <h3>Lifestyles</h3>
        <button type="button" data-action="addItem" data-type="lifestyle" class="btn-add">
          <i class="fas fa-plus"></i>
        </button>
      </div>
      <div class="item-list">
        {{#each lifestyles as |ls|}}
        <div class="item-row flexrow" data-item-id="{{ls.id}}">
          <span class="item-name">{{ls.name}}</span>
          <span>{{ls.system.level}}</span>
          <span>{{ls.system.monthlyCost}}¥/month</span>
          <span>Months: {{ls.system.monthsPaid}}</span>
          <div class="item-controls">
            <a data-action="editItem"><i class="fas fa-edit"></i></a>
            <a data-action="deleteItem"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
      </div>
    </div>

  </div>
</section>
