<section class="tab-content {{#if tab.active}}active{{/if}}" data-tab="gear" data-group="primary">
  <div class="gear-section">

    {{!-- Cyberware --}}
    <div class="gear-category">
      <div class="category-header flexrow">
        <h3>Cyberware</h3>
        <span class="essence-display">Essence: {{formatEssence system.essence.value}} / {{formatEssence system.essence.max}}</span>
        <button type="button" data-action="addItem" data-type="cyberware" class="btn-add">
          <i class="fas fa-plus"></i>
        </button>
      </div>
      <div class="item-list">
        {{#each cyberware as |cyber|}}
        <div class="item-row cyber-row flexrow {{#if cyber.system.installed}}cyber-on{{else}}cyber-off{{/if}}" data-item-id="{{cyber.id}}">
          <span class="item-name">
            <i class="fas fa-microchip"></i>
            {{cyber.name}}
          </span>
          <span class="cyber-location">{{cyber.system.location}}</span>
          <span class="cyber-grade">{{cyber.system.grade}}</span>
          {{#if cyber.system.cranialDeck}}<span class="cyber-mods {{#if cyber.system.deck.active}}bio-active{{/if}}" title="Cranial cyberdeck — MPCP {{cyber.system.deck.mpcp}}. Activate (⚡) to drive the Matrix tab."><i class="fas fa-bolt"></i> C2 MPCP {{cyber.system.deck.mpcp}}{{#if cyber.system.deck.active}} · active{{/if}}</span>{{/if}}
          <span class="cyber-essence">Ess: {{cyber.system.actualEssenceCost}}</span>
          <span class="cyber-installed">
            {{#if cyber.system.installed}}<i class="fas fa-check-circle"></i> Installed{{else}}<i class="fas fa-times-circle"></i> Not installed{{/if}}
          </span>
          <div class="item-controls">
            {{#if cyber.system.cranialDeck}}<a data-action="activateDeck" title="Activate / deactivate this cranial deck (drives the Matrix tab)"><i class="fas fa-bolt {{#if cyber.system.deck.active}}bio-active-icon{{/if}}"></i></a>{{/if}}
            <a data-action="sellItem" title="Sell (refunds what was paid, or the street price)"><i class="fas fa-coins"></i></a>
            <a data-action="toggleEquip" title="Install/Remove"><i class="fas fa-wrench"></i></a>
            <a data-action="editItem"><i class="fas fa-edit"></i></a>
            <a data-action="deleteItem"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- Bioware (Shadowtech) --}}
    <div class="gear-category">
      <div class="category-header flexrow">
        <h3>Bioware</h3>
        <span class="essence-display {{#if bodyIndexOver}}over-cap{{/if}}" title="Body Index — total Body Cost of installed bioware. Max = natural Body. Over the cap is allowed (GM discretion); it inflicts an overstress penalty (Shadowtech p.7).">
          Body Index: {{formatEssence system.bodyIndex.value}} / {{system.bodyIndex.max}}
        </span>
        <button type="button" data-action="addItem" data-type="bioware" class="btn-add">
          <i class="fas fa-plus"></i>
        </button>
      </div>
      {{#if bodyIndexOver}}
      <div class="bioware-overstress-warning" title="System shock: +1 TN to Body tests per point over the cap.">
        <i class="fas fa-triangle-exclamation"></i>
        Over Body Index cap — overstress: +{{bodyIndexOverstress}} TN to Body tests
      </div>
      {{/if}}
      <div class="item-list">
        {{#each bioware as |bio|}}
        <div class="item-row cyber-row flexrow {{#if bio.system.installed}}cyber-on{{else}}cyber-off{{/if}} {{#if bio.system.active}}bio-active-row{{/if}}" data-item-id="{{bio.id}}">
          <span class="item-name">
            <i class="fas fa-dna"></i>
            {{bio.name}}{{#if bio.system.ratingStats.length}} <span class="cyber-rating" title="Rating — edit the item (✏️) to change; higher ratings cost more Body Index">R{{bio.system.rating}}</span>{{/if}}
          </span>
          <span class="cyber-location">{{localize (lookup ../bodySystems bio.system.bodySystem)}}</span>
          <span class="cyber-grade">{{bio.system.grade}}</span>
          {{#if bio.system.triggered}}
            {{#if bio.system.active}}<span class="cyber-mods bio-active" title="Triggered — ACTIVE. Apply these while the surge lasts (see notes)."><i class="fas fa-bolt"></i> {{attrModSummary bio.system.attributeMods bio.system.rating}}</span>
            {{else}}<span class="cyber-mods bio-triggered" title="Triggered implant — click the ⚡ to activate its surge (see notes)."><i class="fas fa-bolt"></i> triggered</span>{{/if}}
          {{else}}
            {{#with (attrModSummary bio.system.attributeMods bio.system.rating) as |summary|}}{{#if summary}}<span class="cyber-mods" title="Passive effect while installed">{{summary}}</span>{{/if}}{{/with}}
          {{/if}}
          {{#if bio.system.armorImpact}}<span class="cyber-mods" title="Subdermal armor (adds to worn armor)">Armor {{bio.system.armorBallistic}}B/{{bio.system.armorImpact}}I</span>{{/if}}
          <span class="cyber-essence" title="Effective Body Cost (cultured applied)">BC: {{formatEssence bio.system.actualBodyCost}}</span>
          <span class="cyber-installed">
            {{#if bio.system.installed}}<i class="fas fa-check-circle"></i> Installed{{else}}<i class="fas fa-times-circle"></i> Not installed{{/if}}
          </span>
          <div class="item-controls">
            {{#if bio.system.triggered}}<a data-action="toggleBioActive" title="Activate / deactivate the implant's surge"><i class="fas fa-bolt {{#if bio.system.active}}bio-active-icon{{/if}}"></i></a>{{/if}}
            <a data-action="sellItem" title="Sell (refunds what was paid, or the street price)"><i class="fas fa-coins"></i></a>
            <a data-action="toggleEquip" title="Install/Remove"><i class="fas fa-wrench"></i></a>
            <a data-action="editItem"><i class="fas fa-edit"></i></a>
            <a data-action="deleteItem"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- Skillsofts --}}
    <div class="gear-category">
      <div class="category-header flexrow">
        <h3>Skillsofts</h3>
        <span class="essence-display" title="ActiveSofts share the Skillwire Rating as a total-rating budget; Know/LinguaSofts need an access port (chipjack/datajack/headware memory); headware memory stores the chips (Mp).">
          ActiveSoft {{skillsoftCapacity.activeUsed}}/{{skillsoftCapacity.skillwiresRating}} · Mem {{skillsoftCapacity.memUsed}}{{#ifGt skillsoftCapacity.memCapacity 0}}/{{skillsoftCapacity.memCapacity}}{{/ifGt}} Mp{{#unless skillsoftCapacity.knowAccess}} · ⚠ no chip access{{/unless}}
        </span>
        <button type="button" data-action="addItem" data-type="gear" data-category="skillsoft" class="btn-add">
          <i class="fas fa-plus"></i>
        </button>
      </div>
      <div class="item-list">
        {{#each skillsofts as |soft|}}
        <div class="item-row flexrow {{#if soft.system.slotted}}soft-slotted{{/if}} {{#if soft.system._overBudget}}soft-overbudget{{/if}}" data-item-id="{{soft.id}}">
          <span class="item-name">{{soft.name}}</span>
          <span class="soft-grant">{{#if soft.system.grantedSkill}}{{soft.system.grantedSkill}} {{soft.system.rating}}{{else}}<em>(set granted skill)</em>{{/if}}</span>
          <span class="soft-type" title="{{soft.system.cost}}¥">{{soft.system.mp}} Mp</span>
          {{#if soft.system._overBudget}}<span class="soft-warn" title="Slotted but not running — over the Skillwire/chipjack capacity"><i class="fas fa-triangle-exclamation"></i></span>{{/if}}
          <div class="item-controls">
            <a data-action="toggleSlot" title="{{#if soft.system.slotted}}Un-slot{{else}}Slot{{/if}}">
              <i class="fas {{#if soft.system.slotted}}fa-bolt{{else}}fa-power-off{{/if}}"></i>
            </a>
            <a data-action="editItem"><i class="fas fa-edit"></i></a>
            <a data-action="deleteItem"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- General Gear --}}
    <div class="gear-category">
      <div class="category-header flexrow">
        <h3>Equipment</h3>
        <button type="button" data-action="addItem" data-type="gear" class="btn-add">
          <i class="fas fa-plus"></i>
        </button>
      </div>
      <div class="item-list">
        {{#each gear as |g|}}
        <div class="item-row flexrow" data-item-id="{{g.id}}">
          <span class="item-name">{{g.name}}</span>
          {{#ifGt g.system.rating 0}}
          <span>Rating: {{g.system.rating}}</span>
          {{/ifGt}}
          {{#if g.system.weaponAccessory}}
          {{#if (and g.system.permanentAccessory g.system.linkedWeaponId)}}
          <span class="weapon-mount" title="Once installed, this accessory cannot be removed (SR2E p.240). Edit the item to override.">
            <i class="fas fa-lock"></i>
            <select data-field="system.linkedWeaponId" disabled>
              {{#each @root.weapons as |w|}}
              <option value="{{w.id}}" {{selected g.system.linkedWeaponId w.id}}>{{w.name}}</option>
              {{/each}}
            </select>
          </span>
          {{else}}
          <span class="weapon-mount" title="Attach this accessory to one weapon; its modifiers then apply to that weapon's attacks. Aftermarket accessories can be detached and moved to another weapon (SR2E p.240–241).">
            <i class="fas fa-link"></i>
            <select data-field="system.linkedWeaponId">
              <option value="" {{#unless g.system.linkedWeaponId}}selected{{/unless}}>— unattached —</option>
              {{#each @root.weapons as |w|}}
              <option value="{{w.id}}" {{selected g.system.linkedWeaponId w.id}}>{{w.name}}</option>
              {{/each}}
            </select>
          </span>
          {{/if}}
          {{else}}
          <span>Qty: {{g.system.quantity}}</span>
          {{/if}}
          <span class="item-price">{{priceTag g.system.cost g.system.streetIndex}}</span>
          <div class="item-controls">
            {{#ifEquals g.system.category "cyberdeck"}}
            <a data-action="activateDeck" class="{{#if g.system.deck.active}}deck-active{{/if}}"
               title="{{#if g.system.deck.active}}Active deck — its specs drive the Matrix tab{{else}}Activate this deck (populates the Matrix tab; deactivates any other deck){{/if}}">
              <i class="fas {{#if g.system.deck.active}}fa-bolt{{else}}fa-power-off{{/if}}"></i>
            </a>
            {{/ifEquals}}
            <a data-action="sellItem" title="Sell (refunds what was paid, or the street price)"><i class="fas fa-coins"></i></a>
            <a data-action="toggleEquip" title="Equip/Unequip">
              <i class="fas {{#if g.system.equipped}}fa-check-circle{{else}}fa-circle{{/if}}"></i>
            </a>
            <a data-action="editItem"><i class="fas fa-edit"></i></a>
            <a data-action="deleteItem"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- Lifestyles --}}
    <div class="gear-category">
      <div class="category-header flexrow">
        <h3>Lifestyles</h3>
        <button type="button" data-action="addItem" data-type="lifestyle" class="btn-add">
          <i class="fas fa-plus"></i>
        </button>
      </div>
      <div class="item-list">
        {{#each lifestyles as |ls|}}
        <div class="item-row flexrow" data-item-id="{{ls.id}}">
          <span class="item-name">{{ls.name}}</span>
          <span>{{ls.system.level}}</span>
          <span>{{ls.system.monthlyCost}}¥/month</span>
          <span>Months: {{ls.system.monthsPaid}}</span>
          <div class="item-controls">
            <a data-action="editItem"><i class="fas fa-edit"></i></a>
            <a data-action="deleteItem"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
      </div>
    </div>

  </div>
</section>
