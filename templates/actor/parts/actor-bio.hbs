<section class="tab-content {{#if tab.active}}active{{/if}}" data-tab="bio" data-group="primary">
  <div class="bio-section">

    <fieldset class="bio-group">
      <legend>Biography</legend>
      <div class="editor-wrapper">
        {{{enrichedBiography}}}
        {{#if editable}}
        <textarea name="system.biography" style="display:none;">{{system.biography}}</textarea>
        {{/if}}
      </div>
    </fieldset>

    <fieldset class="bio-group">
      <legend>Notes</legend>
      <div class="editor-wrapper">
        {{{enrichedNotes}}}
        {{#if editable}}
        <textarea name="system.notes" style="display:none;">{{system.notes}}</textarea>
        {{/if}}
      </div>
    </fieldset>

    {{!-- Karma Ledger --}}
    <fieldset class="bio-group karma-ledger">
      <legend>Karma</legend>
      <div class="karma-ledger-grid">

        <div class="karma-ledger-row">
          <span class="karma-ledger-label" title="Total karma earned by this character over their lifetime">Total Earned</span>
          <input type="number" name="system.karma.total" value="{{system.karma.total}}" min="0" class="karma-ledger-input" />
        </div>

        <div class="karma-ledger-row">
          <span class="karma-ledger-label" title="Karma available to spend on skill/attribute advancement">Good Karma (Available)</span>
          <input type="number" name="system.karma.current" value="{{system.karma.current}}" min="0" class="karma-ledger-input karma-available" />
        </div>

        <div class="karma-ledger-row karma-spent-row">
          <span class="karma-ledger-label" title="Karma already spent on advancement (Total − Available)">Spent</span>
          <span class="karma-ledger-value karma-spent">{{subtract system.karma.total system.karma.current}}</span>
        </div>

        <div class="karma-ledger-divider"></div>

        <div class="karma-ledger-row">
          <span class="karma-ledger-label" title="Karma Pool dice — can be added to any roll, refresh per session/game event">Karma Pool</span>
          <input type="number" name="system.karma.pool" value="{{system.karma.pool}}" min="0" class="karma-ledger-input karma-pool" />
        </div>

      </div>
    </fieldset>

    {{!-- Character Creation Info --}}
    <fieldset class="chargen-info">
      <legend>Character Creation</legend>
      <div class="chargen-grid">
        <div class="priority-row flexrow">
          <label>Race Priority:</label>
          <select name="system.chargen.priorities.race">
            <option value="A" {{selected system.chargen.priorities.race "A"}}>A</option>
            <option value="B" {{selected system.chargen.priorities.race "B"}}>B</option>
            <option value="C" {{selected system.chargen.priorities.race "C"}}>C</option>
            <option value="D" {{selected system.chargen.priorities.race "D"}}>D</option>
            <option value="E" {{selected system.chargen.priorities.race "E"}}>E</option>
          </select>
        </div>
        <div class="priority-row flexrow">
          <label>Magic Priority:</label>
          <select name="system.chargen.priorities.magic">
            <option value="A" {{selected system.chargen.priorities.magic "A"}}>A</option>
            <option value="B" {{selected system.chargen.priorities.magic "B"}}>B</option>
            <option value="C" {{selected system.chargen.priorities.magic "C"}}>C</option>
            <option value="D" {{selected system.chargen.priorities.magic "D"}}>D</option>
            <option value="E" {{selected system.chargen.priorities.magic "E"}}>E</option>
          </select>
        </div>
        <div class="priority-row flexrow">
          <label>Attributes Priority:</label>
          <select name="system.chargen.priorities.attributes">
            <option value="A" {{selected system.chargen.priorities.attributes "A"}}>A</option>
            <option value="B" {{selected system.chargen.priorities.attributes "B"}}>B</option>
            <option value="C" {{selected system.chargen.priorities.attributes "C"}}>C</option>
            <option value="D" {{selected system.chargen.priorities.attributes "D"}}>D</option>
            <option value="E" {{selected system.chargen.priorities.attributes "E"}}>E</option>
          </select>
        </div>
        <div class="priority-row flexrow">
          <label>Skills Priority:</label>
          <select name="system.chargen.priorities.skills">
            <option value="A" {{selected system.chargen.priorities.skills "A"}}>A</option>
            <option value="B" {{selected system.chargen.priorities.skills "B"}}>B</option>
            <option value="C" {{selected system.chargen.priorities.skills "C"}}>C</option>
            <option value="D" {{selected system.chargen.priorities.skills "D"}}>D</option>
            <option value="E" {{selected system.chargen.priorities.skills "E"}}>E</option>
          </select>
        </div>
        <div class="priority-row flexrow">
          <label>Resources Priority:</label>
          <select name="system.chargen.priorities.resources">
            <option value="A" {{selected system.chargen.priorities.resources "A"}}>A</option>
            <option value="B" {{selected system.chargen.priorities.resources "B"}}>B</option>
            <option value="C" {{selected system.chargen.priorities.resources "C"}}>C</option>
            <option value="D" {{selected system.chargen.priorities.resources "D"}}>D</option>
            <option value="E" {{selected system.chargen.priorities.resources "E"}}>E</option>
          </select>
        </div>
      </div>
    </fieldset>

  </div>
</section>
