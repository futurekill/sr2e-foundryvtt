<section class="tab-content {{#if tab.active}}active{{/if}}" data-tab="bio" data-group="primary">
  <div class="bio-section">

    <fieldset class="bio-group">
      <legend>Biography</legend>
      <div class="editor-wrapper">
        {{#if editable}}
        <prose-mirror name="system.biography"
                      value="{{system.biography}}"
                      document-uuid="{{actor.uuid}}"
                      class="sr2e-prose-mirror">
        </prose-mirror>
        {{else}}
        <div class="editor-content bio-enriched">{{{enrichedBiography}}}</div>
        {{/if}}
      </div>
    </fieldset>

    <fieldset class="bio-group">
      <legend>Notes</legend>
      <div class="editor-wrapper">
        {{#if editable}}
        <prose-mirror name="system.notes"
                      value="{{system.notes}}"
                      document-uuid="{{actor.uuid}}"
                      class="sr2e-prose-mirror">
        </prose-mirror>
        {{else}}
        <div class="editor-content bio-enriched">{{{enrichedNotes}}}</div>
        {{/if}}
      </div>
    </fieldset>

    {{!-- Edges & Flaws (qualities) --}}
    <fieldset class="bio-group edges-flaws">
      <legend>Edges &amp; Flaws</legend>
      <div class="edges-flaws-toolbar flexrow">
        <span class="ef-total" title="Net build-point value of all Edges &amp; Flaws (Edges cost points, Flaws grant them)">
          Net value: <strong>{{#ifGt qualityPointTotal 0}}+{{/ifGt}}{{qualityPointTotal}}</strong>
        </span>
        <button type="button" data-action="addItem" data-type="quality" class="btn-add">
          <i class="fas fa-plus"></i> Add Edge / Flaw
        </button>
      </div>
      {{#if qualities.length}}
      <div class="edges-flaws-list">
        {{#each qualities as |q|}}
        <div class="ef-row flexrow" data-item-id="{{q.id}}">
          <span class="ef-kind ef-{{q.system.kind}}">{{q.system.kind}}</span>
          <span class="ef-name">{{q.name}}</span>
          <span class="ef-value" title="Build-point value">{{q.system.signedValue}}</span>
          <span class="ef-controls item-controls">
            <a data-action="editItem" title="Edit"><i class="fas fa-edit"></i></a>
            <a data-action="deleteItem" title="Delete"><i class="fas fa-trash"></i></a>
          </span>
        </div>
        {{/each}}
      </div>
      {{else}}
      <p class="hint ef-empty">No Edges or Flaws. Drag them from the compendium or click <strong>+ Add Edge / Flaw</strong>.</p>
      {{/if}}
    </fieldset>

    {{!-- Karma Ledger --}}
    <fieldset class="bio-group karma-ledger">
      <legend>Karma</legend>
      <div class="karma-ledger-grid">

        <div class="karma-ledger-row">
          <span class="karma-ledger-label" title="Total karma earned by this character over their lifetime">Total Earned</span>
          <input type="number" name="system.karma.total" value="{{system.karma.total}}" min="0" class="karma-ledger-input" />
        </div>

        <div class="karma-ledger-row">
          <span class="karma-ledger-label" title="Karma available to spend on skill/attribute advancement">Good Karma (Available)</span>
          <input type="number" name="system.karma.current" value="{{system.karma.current}}" min="0" class="karma-ledger-input karma-available" />
          <button type="button" data-action="advanceKarma" class="btn-small karma-advance-btn"
                  title="Spend Good Karma to raise an attribute or skill (SR2E p.190)">
            <i class="fas fa-arrow-up"></i> Advance
          </button>
        </div>

        <div class="karma-ledger-row karma-spent-row">
          <span class="karma-ledger-label" title="Karma already spent on advancement (Total − Available)">Spent</span>
          <span class="karma-ledger-value karma-spent">{{subtract system.karma.total system.karma.current}}</span>
        </div>

        <div class="karma-ledger-divider"></div>

        <div class="karma-ledger-row">
          <span class="karma-ledger-label" title="Karma Pool dice — can be added to any roll, refresh per session/game event">Karma Pool</span>
          <input type="number" name="system.karma.pool" value="{{system.karma.pool}}" min="0" class="karma-ledger-input karma-pool" />
        </div>

        <div class="karma-ledger-divider"></div>

        {{!-- Shared Team Karma Pool (SR2E p.246): contribute from / draw into this
              character's Karma Pool. Visible to all players; total stays in sync. --}}
        <div class="karma-ledger-row">
          <span class="karma-ledger-label" title="Shared Team Karma Pool — the team contributes Karma Pool points and draws from it by agreement (SR2E p.246)">Team Karma Pool</span>
          <span class="karma-ledger-value karma-team">{{teamKarma}}</span>
        </div>
        <div class="karma-team-buttons">
          <button type="button" class="karma-team-btn" data-action="contributeTeamKarma" title="Move Karma Pool points from this character into the Team Karma Pool">
            <i class="fas fa-arrow-up"></i> Contribute
          </button>
          <button type="button" class="karma-team-btn" data-action="drawTeamKarma" title="Draw Karma Pool points from the Team Karma Pool into this character">
            <i class="fas fa-arrow-down"></i> Draw
          </button>
        </div>

      </div>
    </fieldset>

    {{!-- Character Creation Info --}}
    <fieldset class="chargen-info">
      <legend>Character Creation</legend>
      <div class="chargen-grid">
        <div class="priority-row flexrow">
          <label title="While ticked: gear buys at LIST price (no Street Index markup) and the point/nuyen budget panel is shown. Untick for ported or karma-advanced characters and when play begins — the budget panel hides so grown-past-creation totals don't flag as over-budget.">Creation in progress:</label>
          <input type="checkbox" name="system.chargen.inProgress" {{checked system.chargen.inProgress}} style="width:auto;" />
        </div>
        <div class="priority-row flexrow">
          <label>Method:</label>
          <select name="system.chargen.priorityMethod">
            <option value="standard" {{#ifEquals priorityMethod "standard"}}selected{{/ifEquals}}>Standard (A–E once each)</option>
            <option value="sumto10" {{#ifEquals priorityMethod "sumto10"}}selected{{/ifEquals}}>Sum-to-10 (Companion)</option>
          </select>
        </div>
        <div class="priority-row flexrow">
          <label>Race Priority:</label>
          <select name="system.chargen.priorities.race">
            {{#each priorityOptions.race as |opt|}}
            <option value="{{opt.grade}}" {{#if opt.selected}}selected{{/if}}>{{opt.label}}</option>
            {{/each}}
          </select>
        </div>
        <div class="priority-row flexrow">
          <label>Magic Priority:</label>
          <select name="system.chargen.priorities.magic">
            {{#each priorityOptions.magic as |opt|}}
            <option value="{{opt.grade}}" {{#if opt.selected}}selected{{/if}}>{{opt.label}}</option>
            {{/each}}
          </select>
        </div>
        <div class="priority-row flexrow">
          <label>Attributes Priority:</label>
          <select name="system.chargen.priorities.attributes">
            {{#each priorityOptions.attributes as |opt|}}
            <option value="{{opt.grade}}" {{#if opt.selected}}selected{{/if}}>{{opt.label}}</option>
            {{/each}}
          </select>
        </div>
        <div class="priority-row flexrow">
          <label>Skills Priority:</label>
          <select name="system.chargen.priorities.skills">
            {{#each priorityOptions.skills as |opt|}}
            <option value="{{opt.grade}}" {{#if opt.selected}}selected{{/if}}>{{opt.label}}</option>
            {{/each}}
          </select>
        </div>
        <div class="priority-row flexrow">
          <label>Resources Priority:</label>
          <select name="system.chargen.priorities.resources">
            {{#each priorityOptions.resources as |opt|}}
            <option value="{{opt.grade}}" {{#if opt.selected}}selected{{/if}}>{{opt.label}}</option>
            {{/each}}
          </select>
        </div>
        {{#ifEquals priorityMethod "sumto10"}}
        <p class="priority-{{#if priorityValid}}ok{{else}}warning{{/if}}">
          {{#if priorityValid}}<i class="fas fa-check"></i>{{else}}<i class="fas fa-triangle-exclamation"></i>{{/if}}
          Sum-to-10: grade values (A=4, B=3, C=2, D=1, E=0) total <strong>{{prioritySum}}</strong> / 10.
          {{#unless priorityValid}}Adjust until the total is exactly 10.{{/unless}}
        </p>
        {{else}}
        {{#unless priorityValid}}
        <p class="priority-warning">
          <i class="fas fa-triangle-exclamation"></i>
          Each priority A–E must be used exactly once. Duplicated:
          <strong>{{#each priorityDuplicates}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</strong>{{#if priorityUnused.length}};
          unused: <strong>{{#each priorityUnused}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</strong>{{/if}}.
        </p>
        {{/unless}}
        {{/ifEquals}}

        {{!-- Live point/nuyen spend vs the chosen priority allotment (p.44–45).
             Only shown while creation is in progress — a karma-advanced or
             ported character has legitimately grown past its starting budget,
             so the "over" flags would be false alarms once play begins. --}}
        {{#if system.chargen.inProgress}}
        <div class="chargen-budget">
          <div class="budget-row flexrow {{#if chargenBudget.attributes.over}}over{{/if}}">
            <span class="budget-label">Attribute Points</span>
            <span class="budget-value">{{chargenBudget.attributes.spent}} / {{chargenBudget.attributes.total}}</span>
            <span class="budget-remaining">{{#if chargenBudget.attributes.over}}<i class="fas fa-triangle-exclamation"></i> {{/if}}{{chargenBudget.attributes.remaining}} left</span>
          </div>
          <div class="budget-row flexrow {{#if chargenBudget.skills.over}}over{{/if}}">
            <span class="budget-label" title="Active + Build/Repair skills. Knowledge, Language and Special skills use the p.74 rules and aren't counted here.">Skill Points</span>
            <span class="budget-value">{{chargenBudget.skills.spent}} / {{chargenBudget.skills.total}}</span>
            <span class="budget-remaining">{{#if chargenBudget.skills.over}}<i class="fas fa-triangle-exclamation"></i> {{/if}}{{chargenBudget.skills.remaining}} left</span>
          </div>
          <div class="budget-row flexrow {{#if chargenBudget.resources.over}}over{{/if}}">
            <span class="budget-label" title="List cost of owned gear, cyberware, foci and lifestyle (no Street Index markup during chargen).">Resources (¥)</span>
            <span class="budget-value">{{chargenBudget.resources.spentFmt}} / {{chargenBudget.resources.totalFmt}}</span>
            <span class="budget-remaining">{{#if chargenBudget.resources.over}}<i class="fas fa-triangle-exclamation"></i> {{/if}}{{chargenBudget.resources.remainingFmt}} left</span>
          </div>
          {{#if chargenShowForce}}
          <div class="budget-row flexrow {{#if chargenBudget.forcePoints.over}}over{{/if}}">
            <span class="budget-label" title="Spell Force totals + focus Bonding costs.">Force Points</span>
            <span class="budget-value">{{chargenBudget.forcePoints.spent}} / {{chargenBudget.forcePoints.total}}</span>
            <span class="budget-remaining">{{#if chargenBudget.forcePoints.over}}<i class="fas fa-triangle-exclamation"></i> {{/if}}{{chargenBudget.forcePoints.remaining}} left</span>
          </div>
          {{/if}}
        </div>
        {{/if}}
      </div>
    </fieldset>

  </div>
</section>
