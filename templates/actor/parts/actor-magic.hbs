<section class="tab-content {{#if tab.active}}active{{/if}}" data-tab="magic" data-group="primary">
  <div class="magic-section">

    {{!-- Magic Configuration --}}
    <fieldset class="magic-config">
      <legend>Magical Tradition</legend>

      {{!-- Tradition drop zone (shown when no tradition is set) --}}
      {{#unless isMagical}}
      <div class="tradition-drop-zone">
        <i class="fas fa-hat-wizard"></i>
        <span>{{localize "SR2E.Magic.DropTradition"}}</span>
      </div>
      {{/unless}}

      {{!-- Tradition display (shown when a tradition is active) --}}
      {{#if isMagical}}
      <div class="tradition-display flexrow">
        <div class="tradition-info">
          <span class="tradition-type">{{magicLabel}}</span>
          {{#if magicSkillLabel}}
          <span class="tradition-skill"> · {{magicSkillLabel}}</span>
          {{/if}}
          <span class="tradition-astral {{#if hasAstral}}astral-yes{{else}}astral-no{{/if}}">
            · {{#if hasAstral}}{{localize "SR2E.Magic.AstralAccess"}}{{else}}{{localize "SR2E.Magic.NoAstralAccess"}}{{/if}}
          </span>
        </div>
        <button type="button" data-action="clearTradition" title="{{localize "SR2E.Magic.ClearTradition"}}" class="tradition-clear btn-small">
          <i class="fas fa-times"></i>
        </button>
      </div>

      {{#ifEquals system.magic.tradition "shamanic"}}
      <div class="form-group">
        <label>Totem:</label>
        <select name="system.magic.totem">
          <option value="">None</option>
          {{#each config.totems as |totem key|}}
          <option value="{{key}}" {{selected ../system.magic.totem key}}>{{localize totem.label}}</option>
          {{/each}}
        </select>
      </div>
      {{/ifEquals}}
      <div class="form-group">
        <label>Magic Rating:</label>
        <input type="number" name="system.magic.value" value="{{system.magic.value}}" min="0" max="{{system.magic.max}}" />
        <span>/ {{system.magic.max}}</span>
      </div>
      <div class="form-group">
        <label>Initiate Grade:</label>
        <input type="number" name="system.magic.initiateGrade" value="{{system.magic.initiateGrade}}" min="0" />
      </div>
      {{#if system.magic.initiateGrade}}
      <div class="form-group metamagic-group">
        <label title="Metamagic techniques learned — one per initiate Grade (Grimoire). Ctrl/Cmd-click to multi-select.">Metamagic:</label>
        <select name="system.magic.metamagic" multiple size="4" class="metamagic-select">
          {{#each config.metamagic as |label key|}}
          <option value="{{key}}" {{selectedIn ../system.magic.metamagic key}}>{{label}}</option>
          {{/each}}
        </select>
        <span class="metamagic-hint">{{system.magic.metamagic.length}} / {{system.magic.initiateGrade}} learned</span>
      </div>
      <div class="form-group">
        <label title="The non-magical skill you Center with (Grimoire p.43). When Centering is learned, it is rolled vs the drain TN on every cast; each 2 successes adds 1 to your drain resistance. Must match one of your skills by name.">Centering Skill:</label>
        <input type="text" name="system.magic.centeringSkill" value="{{system.magic.centeringSkill}}" placeholder="e.g. Athletics, Music" />
      </div>
      {{/if}}
      {{/if}}
    </fieldset>

    {{!-- Astral (SR2E p.145–147) --}}
    {{#if hasAstral}}
    <div class="astral-box flexrow" title="Astrally perceive (dual-natured) or project (astral form acts separately). Projecting initiative = Astral Reaction +15, 1d6 (SR2E p.147)">
      <span class="astral-label"><i class="fas fa-eye"></i> Astral:</span>
      <span class="astral-state {{system.astralState}}">
        {{#ifEquals system.astralState "projecting"}}Projecting{{else}}{{#ifEquals system.astralState "perceiving"}}Perceiving{{else}}Physical{{/ifEquals}}{{/ifEquals}}
      </span>
      <span class="hint" style="flex:1;">Astral Reaction {{system.astralReaction}}</span>
      <button type="button" class="btn-small" data-action="toggleAstral"><i class="fas fa-arrows-rotate"></i> Change</button>
      <button type="button" class="btn-small" data-action="astralAttack" title="Astral attack (SR2E p.147)"><i class="fas fa-hand-fist"></i> Astral Attack</button>
    </div>
    {{/if}}

    {{!-- Spell Defense (SR2E p.132) --}}
    {{#if hasSorcery}}
    <div class="spell-defense-box flexrow" title="Allocate Magic Pool dice as Spell Defense — protects you and allies in line of sight against spells until the Magic Pool refreshes (SR2E p.132)">
      <span class="spell-defense-label"><i class="fas fa-shield-halved"></i> Spell Defense:</span>
      <span class="spell-defense-value">{{system.dicePools.spellDefense}} dice{{#ifGt system.dicePools.shieldingBonus 0}} <span class="shielding-bonus" title="Free Shielding dice from your initiate grade (Grimoire p.45)">+{{system.dicePools.shieldingBonus}} shielding</span>{{/ifGt}}</span>
      <span class="hint" style="flex:1;">(Magic Pool: {{system.dicePools.magic.value}}/{{system.dicePools.magic.max}})</span>
      <button type="button" class="btn-small" data-action="allocateSpellDefense"><i class="fas fa-plus"></i> Allocate</button>
      <button type="button" class="btn-small" data-action="clearSpellDefense"><i class="fas fa-rotate-left"></i> Clear</button>
    </div>
    {{/if}}

    {{!-- Spells --}}
    {{#if hasSorcery}}
    <div class="spells-category">
      <div class="category-header flexrow">
        <h3>Spells</h3>
        <button type="button" data-action="addItem" data-type="spell" class="btn-add">
          <i class="fas fa-plus"></i>
        </button>
      </div>
      <div class="spell-list-header flexrow">
        <span class="spell-col name">Name</span>
        <span class="spell-col category">Category</span>
        <span class="spell-col type">Type</span>
        <span class="spell-col drain">Drain</span>
        <span class="spell-col controls">Controls</span>
      </div>
      <div class="item-list">
        {{#each spells as |spell|}}
        <div class="item-row spell-row flexrow {{#if spell.system.sustaining}}sustaining{{/if}}" data-item-id="{{spell.id}}">
          <span class="spell-col name" data-action="castSpell">
            <i class="fas fa-magic"></i>
            {{spell.name}}
            {{#if spell.system.sustaining}}
            <span class="sustain-badge" title="Sustained at Force {{spell.system.sustainedForce}}">F{{spell.system.sustainedForce}}</span>
            {{/if}}
          </span>
          <span class="spell-col category">{{spell.system.category}}</span>
          <span class="spell-col type">{{spell.system.type}}</span>
          <span class="spell-col drain">{{spell.system.drainCode}}</span>
          <div class="spell-col controls item-controls">
            {{#ifEquals spell.system.duration "sustained"}}
            <a data-action="toggleSustain" class="sustain-toggle {{#if spell.system.sustaining}}active{{/if}}"
               title="{{#if spell.system.sustaining}}Drop spell (Free Action){{else}}Sustain (+2 TN on all other tests, SR2E p.130){{/if}}">
              <i class="fas fa-hourglass-half"></i>
            </a>
            {{#if spell.system.sustaining}}
            <a data-action="toggleSpellLock" class="spell-lock-toggle {{#if spell.system.spellLocked}}active{{/if}}"
               title="{{#if spell.system.spellLocked}}Held by spell lock (no sustain penalty){{else}}Hold with a spell lock (removes the +2 TN penalty){{/if}}">
              <i class="fas fa-lock"></i>
            </a>
            {{#if spell.system.quickened}}
            <a class="quicken-toggle active"
               title="Quickened — permanent for {{spell.system.quickeningKarma}} Karma; no sustaining penalty (Grimoire p.44)">
              <i class="fas fa-infinity"></i>
            </a>
            {{else}}
            <a data-action="quickenSpell" class="quicken-toggle"
               title="Quicken (initiate metamagic) — pay the spell's Force in Karma to make it permanent with no sustaining penalty (Grimoire p.44)">
              <i class="fas fa-infinity"></i>
            </a>
            {{/if}}
            {{/if}}
            {{/ifEquals}}
            <a data-action="editItem" title="Edit"><i class="fas fa-edit"></i></a>
            <a data-action="deleteItem" title="Delete"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
        {{#ifGt sustainPenalty 0}}
        <div class="sustain-summary" title="+2 TN per spell sustained by concentration (SR2E p.130)">
          <i class="fas fa-hourglass-half"></i>
          Sustaining &mdash; <strong>+{{sustainPenalty}} TN</strong> on all other tests
        </div>
        {{/ifGt}}
      </div>
    </div>

    {{!-- Conjuring --}}
    {{#if hasConjuring}}
    <div class="conjuring-category">
      <div class="category-header flexrow">
        <h3>Spirits</h3>
        <button type="button" data-action="conjure" data-kind="{{#if conjuresElementals}}elemental{{else}}nature{{/if}}" class="btn-add"
                title="{{#if conjuresElementals}}Summon an elemental (SR2E p.140){{else}}Summon a nature spirit in its domain (SR2E p.138){{/if}}">
          <i class="fas fa-hand-sparkles"></i> {{#if conjuresElementals}}Summon Elemental{{else}}Summon Spirit{{/if}}
        </button>
      </div>
      <div class="item-list">
        {{#each boundSpirits as |spirit|}}
        <div class="item-row spirit-row flexrow" data-spirit-uuid="{{spirit.uuid}}">
          <span class="item-name" data-action="openSpirit">
            <i class="fas fa-ghost"></i> {{spirit.name}}
          </span>
          <span class="spirit-services" title="Services remaining">
            {{spirit.system.services}}/{{spirit.system.maxServices}} svc
          </span>
          <div class="item-controls">
            <a data-action="openSpirit" title="Open spirit sheet"><i class="fas fa-external-link-alt"></i></a>
            <a data-action="banishSpirit" title="Banish spirit"><i class="fas fa-times"></i></a>
          </div>
        </div>
        {{else}}
        <p class="hint" style="padding:2px 6px;">No spirits in service.</p>
        {{/each}}
      </div>
    </div>
    {{/if}}

    {{!-- Foci --}}
    <div class="foci-category">
      <div class="category-header flexrow">
        <h3>Foci</h3>
        <button type="button" data-action="addItem" data-type="focus" class="btn-add">
          <i class="fas fa-plus"></i>
        </button>
      </div>
      <div class="item-list">
        {{#each foci as |focus|}}
        <div class="item-row flexrow" data-item-id="{{focus.id}}">
          <span class="item-name">{{focus.name}}</span>
          <span>{{focus.system.focusType}}</span>
          <span>Force: {{focus.system.force}}</span>
          <span>{{#if focus.system.bonded}}Bonded{{else}}Unbonded{{/if}}</span>
          <div class="item-controls">
            {{#if focus.system.expendable}}<a data-action="spendFocus" title="Spend (single-use)"><i class="fas fa-bolt"></i></a>{{/if}}
            <a data-action="editItem"><i class="fas fa-edit"></i></a>
            <a data-action="deleteItem"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
      </div>
    </div>

    {{/if}}

    {{!-- Adept Powers (Physical Adepts and Shamanic Adepts). Rendered outside
         the isMagical block so dragged-on powers are never invisible — a
         warning shows when the character's magic type doesn't grant them. --}}
    {{#if hasAdeptPowers}}
    <div class="adept-powers-category">
      <div class="category-header flexrow">
        <h3>Adept Powers</h3>
        <span class="power-points">Points: {{system.adeptPowerPoints.value}} / {{system.adeptPowerPoints.max}}</span>
        <button type="button" data-action="addItem" data-type="adept_power" class="btn-add">
          <i class="fas fa-plus"></i>
        </button>
      </div>
      {{#unless isAdept}}
      <p class="hint" style="color:#c84;margin:2px 0 4px;">
        This character's magic type does not grant adept powers — set the
        tradition to Physical Adept (or Shamanic Adept) for them to apply.
      </p>
      {{/unless}}
      <div class="item-list">
        {{#each adeptPowers as |power|}}
        <div class="item-row flexrow" data-item-id="{{power.id}}">
          <span class="item-name">{{power.name}}</span>
          <span>Level: {{power.system.level}}</span>
          <span>Cost: {{power.system.totalCost}}</span>
          <div class="item-controls">
            <a data-action="editItem"><i class="fas fa-edit"></i></a>
            <a data-action="deleteItem"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}

  </div>
</section>
